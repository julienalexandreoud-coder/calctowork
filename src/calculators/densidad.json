      "default": 50,
      "unit": ""
    }
  ],
  "formula": "var m=parseFloat(inputs.masa)||0,v=parseFloat(inputs.volumen)||0;if(!v)return{error:true};return{densidad:+(m/v).toFixed(4),densidad_gl:+(m/v*0.001).toFixed(4)};",
