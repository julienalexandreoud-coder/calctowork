  ],
  "formula": "var b1=parseFloat(inputs.band1)||0;var b2=parseFloat(inputs.band2)||0;var m=parseFloat(inputs.multiplier)||0;var r=(b1*10+b2)*Math.pow(10,m);return{resistance:r,tolerance:5};",
  "outputs": [
    {
      "id": "resistance",
      "unit": "Ω"
    },
    {
      "id": "tolerance",
      "unit": "%"
    }
  ],
