  "formula": "var n=parseFloat(inputs.n)||0,r=parseFloat(inputs.r)||0;function fact(x){var f=1;for(var i=2;i<=x;i++)f*=i;return f;}return{combinaciones:Math.floor(fact(n)/(fact(r)*fact(n-r))),permutaciones:Math.floor(fact(n)/fact(n-r))};",
