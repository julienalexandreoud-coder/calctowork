  "formula": "var Q=parseFloat(inputs.caudal_m3h)||0,v=parseFloat(inputs.velocidad_ms)||4;if(!Q)return{error:true};var A_m2=Q/3600/v,D_mm=+(Math.sqrt(4*A_m2/Math.PI)*1000).toFixed(0),D_norm=D_mm<=100?100:D_mm<=125?125:D_mm<=160?160:D_mm<=200?200:D_mm<=250?250:D_mm<=315?315:400,lado=+(Math.sqrt(A_m2)*1000).toFixed(0);return{area_conducto_m2:+A_m2.toFixed(4),diametro_circular_mm:D_norm,lado_rectangular_mm:lado};",
  "outputs": [
    {
      "id": "diametro_circular_mm",
      "unit": "mm Ã˜ (circular)",
      "highlight": true
    },
