{
  "id": "025",
  "slug": "marmol-granito",
  "block": 3,
  "block_slug": "pavimentos",
  "inputs": [
    {
      "id": "area",
      "type": "number",
      "min": 0.5,
      "max": 500,
      "step": 0.5,
      "default": 15,
      "unit": "m²",
      "unit_options": [
        "m²",
        "ft²"
      ],
      "unit_category": "area"
    },
    {
      "id": "espesor_cm",
      "type": "number",
      "min": 1,
      "max": 5,
      "step": 0.5,
      "default": 2,
      "unit": "cm",
      "unit_options": [
        "cm",
        "m",
        "mm",
        "in"
      ],
      "unit_category": "length"
    },
    {
      "id": "tipo",
      "type": "select",
      "default": "marmol",
      "options": [
        "marmol",
        "granito",
        "cuarcita"
      ]
    }
  ],
  "formula": "var A=parseFloat(inputs.area)||0,E=parseFloat(inputs.espesor_cm)||2;if(!A)return{error:true};var area_merma=+(A*1.08).toFixed(2),densidad=inputs.tipo==='granito'?2700:2700,peso=+(area_merma*E/100*densidad).toFixed(0),adhesivo=+(area_merma*6).toFixed(1);return{area_merma_m2:area_merma,peso_total_kg:peso,adhesivo_kg:adhesivo};",
  "outputs": [
    {
      "id": "area_merma_m2",
      "unit": "m² (+8% merma)",
      "highlight": true
    },
    {
      "id": "peso_total_kg",
      "unit": "kg"
    },
    {
      "id": "adhesivo_kg",
      "unit": "kg"
    }
  ],
  "related": [
