        "EUR",
        "GBP"
      ],
      "unit_category": "currency"
    }
  ],
  "formula": "var inc=parseFloat(inputs.income)||0;var y=parseFloat(inputs.years)||0;var debts=parseFloat(inputs.debts)||0;var sav=parseFloat(inputs.savings)||0;var needed=inc*y+debts-sav;return{needed:needed.toFixed(2)};",
  "outputs": [
    {
      "id": "needed",
      "unit": "USD"
    }
  ],
