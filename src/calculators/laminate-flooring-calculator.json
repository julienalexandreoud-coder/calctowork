      "type": "number",
      "min": 10,
      "max": 30,
      "step": 1,
      "default": 19,
      "unit": "cm",
      "unit_category": "length"
    },
    {
      "id": "planks_per_box",
      "type": "number",
      "min": 5,
      "max": 20,
      "step": 1,
      "default": 8,
      "unit": "pcs",
      "unit_category": "count"
    }
  ],
  "outputs": [
    {
      "id": "room_area_m2",
      "unit": "m²",
      "highlight": true
    },
    {
      "id": "planks_needed",
      "unit": "planks"
    },
    {
      "id": "boxes_needed",
      "unit": "boxes"
    },
    {
      "id": "waste_percent",
      "unit": "%"
    }
  ],
  "formula": "var L=parseFloat(inputs.room_length)||0,W=parseFloat(inputs.room_width)||0,pl=parseFloat(inputs.plank_length)||1.22,pw=parseFloat(inputs.plank_width)||0.193,ppb=parseFloat(inputs.planks_per_box)||8;if(!L||!W)return{error:true};var area=+(L*W).toFixed(2),pa=pl*pw,planks=Math.ceil(area/pa*1.10),boxes=Math.ceil(planks/ppb),waste=+(Math.max(10,((planks*pa/area)-1)*100)).toFixed(1);return{room_area_m2:area,planks_needed:planks,boxes_needed:boxes,waste_percent:waste};",
