  "id": "1061",
  "slug": "tasa-metabolica-mifflin",
  "block": "salud",
  "formula": "var p=parseFloat(inputs.peso)||70,alt=parseFloat(inputs.altura_cm)||170,ed=parseFloat(inputs.edad)||30,s=inputs.sexo||\"hombre\";var tmb;if(s==\"hombre\")tmb=10*p+6.25*alt-5*ed+5;else tmb=10*p+6.25*alt-5*ed-161;return{tmb:+tmb.toFixed(0)};",
