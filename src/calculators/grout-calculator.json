    {
      "id": "bags_10kg",
      "unit": "bags"
    },
    {
      "id": "coverage_m2_per_kg",
      "unit": "m²/kg"
    }
  ],
  "formula": "var tl=parseFloat(inputs.tile_length)||0,tw=parseFloat(inputs.tile_width)||0,ta=parseFloat(inputs.tile_area)||1,gw=parseFloat(inputs.grout_width)||3,tt=parseFloat(inputs.tile_thickness)||8;if(!tl||!tw)return{error:true};var tl_m=tl/100,tw_m=tw/100,cov=+(tl_m*tw_m/(gw/1000*tt/1000*(tl_m+tw_m))/1.7).toFixed(2),kg=+(ta/cov).toFixed(2),b5=Math.ceil(kg/5),b10=Math.ceil(kg/10);return{grout_kg_needed:kg,bags_5kg:b5,bags_10kg:b10,coverage_m2_per_kg:cov};",
