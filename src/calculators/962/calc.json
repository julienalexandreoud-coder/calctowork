      "id": "colesterol_total",
      "type": "number",
      "min": 50,
      "max": 500,
      "step": 1,
      "default": 200,
      "unit": "mg/dL"
    },
    {
      "id": "hdl",
      "type": "number",
      "min": 10,
      "max": 150,
      "step": 1,
      "default": 50,
      "unit": "mg/dL"
    },
    {
      "id": "trigliceridos",
      "type": "number",
      "min": 20,
      "max": 1000,
      "step": 1,
      "default": 150,
      "unit": "mg/dL"
    }
  ],
  "formula": "var total=parseFloat(inputs.colesterol_total)||0,hdl=parseFloat(inputs.hdl)||0,trig=parseFloat(inputs.trigliceridos)||0;if(!total||!hdl)return{error:true};var ldl=+(total-hdl-trig/5).toFixed(1);var ratio=+(total/hdl).toFixed(1);return{ldl:ldl+' mg/dL',total_hdl_ratio:ratio,risk:ratio<3.5?'Low':ratio<5?'Moderate':'High'};",
  "outputs": [
    {
      "id": "ldl",
      "unit": "mg/dL",
      "highlight": true
    },
    {
      "id": "total_hdl_ratio",
      "unit": "",
      "highlight": false
    },
    {
      "id": "risk",
      "unit": "",
      "highlight": false
    }
  ],
