  "formula": "var L=parseFloat(inputs.deck_length)||0,W=parseFloat(inputs.deck_width)||0,bw=parseFloat(inputs.board_width)||14,bl=parseFloat(inputs.board_length)||3.6,gap=parseFloat(inputs.gap_size)||0.6;if(!L||!W||!bw||!bl)return{error:true};var area=+(L*W).toFixed(2),eff=(bw+gap)/100,rows=Math.ceil(W/eff),bpr=Math.ceil(L/bl),boards=rows*bpr,tlm=+(boards*bl).toFixed(1),waste=+(Math.max(5,((boards*bl*eff/area)-1)*100)).toFixed(1);return{deck_area_m2:area,boards_needed:boards,board_rows:rows,waste_percent:waste,total_linear_meters:tlm};",
