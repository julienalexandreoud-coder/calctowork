  "formula": "var A=parseFloat(inputs.area)||0,mxc=parseFloat(inputs.m2_por_caja)||1.44;if(!A)return{error:true};var area_merma=+(A*1.10).toFixed(2),cajas=Math.ceil(area_merma/mxc),adhesivo=+(area_merma*6).toFixed(1),lechada=+(area_merma*0.35).toFixed(1);return{area_merma_m2:area_merma,cajas_ud:cajas,adhesivo_kg:adhesivo,lechada_kg:lechada};",
