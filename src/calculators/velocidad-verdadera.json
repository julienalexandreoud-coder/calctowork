  "id": "1047",
  "slug": "velocidad-verdadera",
  "block": 11,
  "block_slug": "transporte",
  "inputs": [
    {
      "id": "ias",
      "type": "number",
      "step": "any",
      "default": 120,
      "unit": "kt",
      "unit_options": [
        "kt",
        "km/h",
        "mph"
      ],
      "unit_category": "speed"
    },
    {
      "id": "altitude",
      "type": "number",
      "step": "any",
      "default": 5000,
      "unit": "ft",
      "unit_options": [
        "ft",
        "m"
      ],
      "unit_category": "length"
    },
    {
      "id": "temp",
      "type": "number",
      "step": "any",
      "default": 5,
      "unit": "°C",
      "unit_options": [
        "°C",
        "°F"
      ],
      "unit_category": "temperature"
    }
  ],
  "formula": "var ias=parseFloat(inputs.ias)||0;var alt=parseFloat(inputs.altitude)||0;var t=parseFloat(inputs.temp)||0;var tas=ias*(1+alt/1000*0.02)*(1+(t-15)/273);return{tas:tas.toFixed(1)};",
  "outputs": [
    {
      "id": "tas",
      "unit": "kt"
    }
  ],
  "related": [
