{
  "id": "1101",
  "slug": "sod-turf-calculator",
  "block": 1,
  "block_slug": "estructuras",
  "inputs": [
    {
      "id": "lawn_length",
      "type": "number",
      "min": 0.1,
      "max": 100,
      "step": 0.1,
      "default": 10,
      "unit": "m",
      "unit_category": "length"
    },
    {
      "id": "lawn_width",
      "type": "number",
      "min": 0.1,
      "max": 50,
      "step": 0.1,
      "default": 5,
      "unit": "m",
      "unit_category": "length"
    },
    {
      "id": "roll_width",
      "type": "number",
      "min": 0.3,
      "max": 1,
      "step": 0.05,
      "default": 0.6,
      "unit": "m",
      "unit_category": "length"
    },
    {
      "id": "roll_length",
      "type": "number",
      "min": 1,
      "max": 3,
      "step": 0.1,
      "default": 1.5,
      "unit": "m",
      "unit_category": "length"
    }
  ],
  "outputs": [
    {
      "id": "lawn_area_m2",
      "unit": "m²",
      "highlight": true
    },
    {
      "id": "rolls_needed",
      "unit": "rolls"
    },
    {
      "id": "rolls_with_waste",
      "unit": "rolls"
    },
    {
      "id": "coverage_m2_per_roll",
      "unit": "m²"
    }
  ],
  "formula": "var L=parseFloat(inputs.lawn_length)||0,W=parseFloat(inputs.lawn_width)||0,rw=parseFloat(inputs.roll_width)||0.6,rl=parseFloat(inputs.roll_length)||1.5;if(!L||!W)return{error:true};var area=+(L*W).toFixed(2),ra=+(rw*rl).toFixed(3),rolls=Math.ceil(area/ra),rolls_w=Math.ceil(area*1.05/ra);return{lawn_area_m2:area,rolls_needed:rolls,rolls_with_waste:rolls_w,coverage_m2_per_roll:ra};",
  "example_inputs": {
    "lawn_length": 10,
    "lawn_width": 8,
    "roll_width": 0.6,
    "roll_length": 2
  },
