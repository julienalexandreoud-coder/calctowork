  "slug": "cambio-porcentual",
  "block": 10,
  "block_slug": "matematicas",
  "inputs": [
    {
      "id": "valor_inicial",
      "type": "number",
      "min": -1000000000000,
      "max": 1000000000000,
      "step": "any",
      "default": 80,
      "unit": ""
    },
    {
      "id": "valor_final",
      "type": "number",
      "min": -1000000000000,
      "max": 1000000000000,
      "step": "any",
      "default": 100,
      "unit": ""
    }
  ],
  "formula": "var V1=parseFloat(inputs.valor_inicial),V2=parseFloat(inputs.valor_final);if(isNaN(V1)||isNaN(V2)||V1===0)return{error:true};var cambio=+((V2-V1)/Math.abs(V1)*100).toFixed(2),diferencia=+(V2-V1).toFixed(6);return{cambio_pct:cambio,diferencia:diferencia};",
  "outputs": [
    {
      "id": "cambio_pct",
      "unit": "%",
      "highlight": true
    },
    {
      "id": "diferencia",
      "unit": ""
    }
  ],
