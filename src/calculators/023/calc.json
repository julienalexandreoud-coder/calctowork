  ],
  "formula": "var A=parseFloat(inputs.area)||0,mxc=parseFloat(inputs.m2_por_caja)||2.5;if(!A)return{error:true};var area_merma=+(A*1.08).toFixed(2),cajas=Math.ceil(area_merma/mxc),sotobanda=+(area_merma*1.05).toFixed(2),rodc=Math.ceil(area_merma/15);return{area_merma_m2:area_merma,cajas_ud:cajas,sotobanda_m2:sotobanda,rodapie_ml:+(Math.sqrt(A)*4).toFixed(1)};",
