{
  "id": "1045",
  "slug": "viento-cruzado",
  "block": 2,
  "block_slug": "transporte",
  "inputs": [
    {
      "id": "wind_dir",
      "type": "number",
      "step": "any",
      "default": 270,
      "unit": "deg",
      "unit_options": [
        "deg"
      ],
      "unit_category": "angle"
    },
    {
      "id": "runway",
      "type": "number",
      "step": "any",
      "default": 360,
      "unit": "deg",
      "unit_options": [
        "deg"
      ],
      "unit_category": "angle"
    },
    {
      "id": "wind_speed",
      "type": "number",
      "step": "any",
      "default": 20,
      "unit": "kt",
      "unit_options": [
        "kt",
        "km/h",
        "mph"
      ],
      "unit_category": "speed"
    }
  ],
  "formula": "var wd=(parseFloat(inputs.wind_dir)||0)*Math.PI/180;var rw=(parseFloat(inputs.runway)||0)*Math.PI/180;var ws=parseFloat(inputs.wind_speed)||0;var angle=wd-rw;var cw=ws*Math.sin(angle);var hw=ws*Math.cos(angle);return{crosswind:Math.abs(cw).toFixed(1),headwind:hw.toFixed(1)};",
  "outputs": [
    {
      "id": "crosswind",
      "unit": "kt"
    },
    {
      "id": "headwind",
      "unit": "kt"
    }
  ],
