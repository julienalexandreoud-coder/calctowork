  "formula": "var L=parseFloat(inputs.largo_m)||0,W=parseFloat(inputs.ancho_m)||0,H=parseFloat(inputs.profundidad_media_m)||1.5,T=parseFloat(inputs.turnos_dia)||2;if(!L||!W)return{error:true};var vol=+(L*W*H).toFixed(1),caudal=+(vol/T/8).toFixed(2),filtro_m2=+(caudal/20).toFixed(2),cloro_sem=+(vol*0.003).toFixed(2);return{vol_m3:vol,caudal_m3h:caudal,filtro_area_m2:filtro_m2,cloro_semanal_kg:cloro_sem};",
