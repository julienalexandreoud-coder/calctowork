  ],
  "formula": "var L=parseFloat(inputs.luz_m)||0,q=parseFloat(inputs.carga_kn_m2)||5,Ln=parseFloat(inputs.longitud_nave_m)||20;if(!L)return{error:true};var M=+(q*L*L/8).toFixed(2),Wy=+(M*100/23.5).toFixed(0),kg_ml={IPE:+(Wy*0.035).toFixed(1),HEB:+(Wy*0.055).toFixed(1),UPN:+(Wy*0.040).toFixed(1)},pm=kg_ml[inputs.perfil_tipo]||(Wy*0.035).toFixed(1),kg_viga=+(pm*L).toFixed(1),n_vigas=Math.ceil(Ln/6)+1,kg_total=+(kg_viga*n_vigas).toFixed(0),pintura=+(kg_total*0.025).toFixed(1);return{momento_kn_m:M,modulo_resist_cm3:Wy,kg_por_viga:kg_viga,vigas_ud:n_vigas,kg_total:kg_total,pintura_m2:+pintura.toFixed(1)};",
  "outputs": [
    {
      "id": "momento_kn_m",
      "unit": "kN·m"
    },
    {
      "id": "modulo_resist_cm3",
      "unit": "cm³ Wy mín."
    },
    {
      "id": "kg_por_viga",
      "unit": "kg/viga"
    },
    {
      "id": "vigas_ud",
