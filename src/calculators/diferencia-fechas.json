      "min": 1,
      "max": 12,
      "step": 1,
      "default": 4,
      "unit": "mes"
    }
  ],
  "formula": "var y1=parseFloat(inputs.anio1)||0,m1=parseFloat(inputs.mes1)||1,y2=parseFloat(inputs.anio2)||0,m2=parseFloat(inputs.mes2)||1;if(!y1||!y2)return{error:true};var d1=new Date(y1,m1-1,1),d2=new Date(y2,m2-1,1),ms=Math.abs(d2-d1),dias=Math.round(ms/86400000),meses=Math.round(dias/30.44),semanas=Math.round(dias/7),anios=+(dias/365.25).toFixed(2);return{dias:dias,semanas:semanas,meses:meses,anios:anios};",
