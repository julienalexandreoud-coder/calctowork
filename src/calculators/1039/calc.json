{
  "id": "1039",
  "slug": "valor-exposicion",
  "block": 1,
  "block_slug": "fotografia",
  "inputs": [
    {
      "id": "aperture",
      "type": "number",
      "step": "any",
      "default": 2.8,
      "unit": "f/",
      "unit_options": [
        "f/"
      ],
      "unit_category": ""
    },
    {
      "id": "shutter",
      "type": "number",
      "step": "any",
      "default": 125,
      "unit": "1/s",
      "unit_options": [
        "1/s"
      ],
      "unit_category": ""
    },
    {
      "id": "iso",
      "type": "number",
      "step": 1,
      "default": 100,
      "unit": "ISO",
      "unit_options": [
        "ISO"
      ],
      "unit_category": ""
    }
  ],
  "formula": "var a=parseFloat(inputs.aperture)||1;var s=parseFloat(inputs.shutter)||1;var iso=parseFloat(inputs.iso)||100;var ev=Math.log2((a*a)/(1/s))-Math.log2(iso/100);return{ev:ev.toFixed(2)};",
  "outputs": [
    {
      "id": "ev",
      "unit": "EV"
    }
  ],
