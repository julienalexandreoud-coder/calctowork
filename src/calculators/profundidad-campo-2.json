      "default": 2.8,
      "unit": "f/",
      "unit_options": [
        "f/"
      ],
      "unit_category": ""
    },
    {
      "id": "distance",
      "type": "number",
      "step": "any",
      "default": 3,
      "unit": "m",
      "unit_options": [
        "m",
        "ft"
      ],
      "unit_category": "length"
    },
    {
      "id": "coc",
      "type": "number",
      "step": "any",
      "default": 0.03,
      "unit": "mm",
      "unit_options": [
        "mm"
      ],
      "unit_category": "length"
    }
  ],
  "formula": "var f=parseFloat(inputs.focal)||1;var a=parseFloat(inputs.aperture)||1;var d=parseFloat(inputs.distance)||1;var c=parseFloat(inputs.coc)||0.03;var dof=2*d*d*(a*c)/(f*f);return{dof:dof.toFixed(3)};",
  "outputs": [
    {
      "id": "dof",
      "unit": "m"
    }
  ],
