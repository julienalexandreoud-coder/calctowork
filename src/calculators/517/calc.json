  "formula": "var d=parseFloat(inputs.distance)||0;var m=inputs.medium||'fiber';var speed=m==='fiber'?2e8:m==='copper'?2.3e8:3e8;var lt=(d*1000/speed)*1000;var theo=lt*2;return{latency:lt.toFixed(2),theoretical:theo.toFixed(2)};",
  "outputs": [
    {
      "id": "latency",
      "unit": "ms"
    },
