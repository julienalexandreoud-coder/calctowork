  "formula": "var A=parseFloat(inputs.area_m2)||0,kg_m2={'proyectado':1.5,'rodillo_gota':0.8,'veneciano':1.2,'estuco':1.0};if(!A)return{error:true};var kg_ud=kg_m2[inputs.tipo_textura]||1,total=+(A*kg_ud*1.1).toFixed(1),sacos=Math.ceil(total/25);return{kg_m2:kg_ud,kg_total:total,sacos_25kg:sacos};",
