{
  "id": "033",
  "slug": "presion-agua",
  "block": 4,
  "block_slug": "fontaneria",
  "inputs": [
    {
      "id": "altura_m",
      "type": "number",
      "min": 0.1,
      "max": 100,
      "step": 0.1,
      "default": 10,
      "unit": "m",
      "unit_options": [
        "m",
        "cm",
        "mm",
        "ft",
        "in"
      ],
      "unit_category": "length"
    },
    {
      "id": "perdidas_carga_pct",
      "type": "number",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 15,
      "unit": "%",
      "unit_options": [
        "%"
      ],
      "unit_category": "ratio"
    }
  ],
  "formula": "var H=parseFloat(inputs.altura_m)||0,ploss=parseFloat(inputs.perdidas_carga_pct)||15;if(!H)return{error:true};var bar_bruto=+(H*0.0981).toFixed(3),bar_neto=+(bar_bruto*(1-ploss/100)).toFixed(3),psi=+(bar_neto*14.504).toFixed(1),kpa=+(bar_neto*100).toFixed(1);return{bar_bruto:bar_bruto,bar_neto:bar_neto,psi:psi,kpa:kpa};",
  "outputs": [
    {
      "id": "bar_bruto",
      "unit": "bar (bruto)"
    },
    {
      "id": "bar_neto",
      "unit": "bar (con pérdidas)",
      "highlight": true
    },
    {
      "id": "psi",
      "unit": "PSI"
    },
    {
      "id": "kpa",
      "unit": "kPa"
    }
  ],
