{
  "id": "1111",
  "slug": "paint-coverage-calculator",
  "block": 8,
  "block_slug": "pintura",
  "inputs": [
    {
      "id": "wall_length",
      "type": "number",
      "min": 0.1,
      "max": 100,
      "step": 0.1,
      "default": 5,
      "unit": "m",
      "unit_category": "length"
    },
    {
      "id": "wall_height",
      "type": "number",
      "min": 1,
      "max": 10,
      "step": 0.1,
      "default": 2.7,
      "unit": "m",
      "unit_category": "length"
    },
    {
      "id": "coats",
      "type": "number",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2,
      "unit": "pcs",
      "unit_category": "count"
    },
    {
      "id": "paint_type",
      "type": "select",
