        {
          "value": "latex",
          "label": "Latex (10 m²/L)"
        },
        {
          "value": "oil",
          "label": "Oil-based (8 m²/L)"
        }
      ],
      "default": "latex"
    },
    {
      "id": "doors_windows",
      "type": "number",
      "min": 0,
      "max": 10,
      "step": 1,
      "default": 1,
      "unit": "pcs",
      "unit_category": "count"
    }
  ],
  "outputs": [
    {
      "id": "paintable_area_m2",
      "unit": "m²",
      "highlight": true
    },
    {
      "id": "litres_needed",
      "unit": "L"
    },
    {
      "id": "gallons_needed",
      "unit": "gal"
    },
    {
      "id": "cans_5L",
      "unit": "cans"
    }
  ],
  "formula": "var L=parseFloat(inputs.wall_length)||0,H=parseFloat(inputs.wall_height)||0,coats=parseFloat(inputs.coats)||2,pt=inputs.paint_type||'standard',dw=parseFloat(inputs.doors_windows)||0;if(!L||!H)return{error:true};var raw=+(L*H-dw).toFixed(2),area=+(raw*coats).toFixed(2),cov={'standard':12,'premium':10,'matte':10,'gloss':14},c=cov[pt]||12,litres=+(area/c).toFixed(2),gallons=+(litres*0.264).toFixed(2),cans5=Math.ceil(litres/5);return{paintable_area_m2:raw,litres_needed:litres,gallons_needed:gallons,cans_5L:cans5};",
