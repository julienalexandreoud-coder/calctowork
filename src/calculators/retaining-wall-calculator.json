    },
    {
      "id": "block_length",
      "type": "number",
      "min": 20,
      "max": 60,
      "step": 5,
      "default": 40,
      "unit": "cm",
      "unit_category": "length"
    },
    {
      "id": "block_height",
      "type": "number",
      "min": 10,
      "max": 30,
      "step": 5,
      "default": 20,
      "unit": "cm",
      "unit_category": "length"
    }
  ],
  "outputs": [
    {
      "id": "blocks_needed",
      "unit": "blocks",
      "highlight": true
    },
    {
      "id": "gravel_tonnes",
      "unit": "t"
    },
    {
      "id": "base_depth_cm",
      "unit": "cm"
    },
    {
      "id": "drainage_pipe_m",
      "unit": "m"
    }
  ],
  "formula": "var L=parseFloat(inputs.wall_length)||0,H=parseFloat(inputs.wall_height)||0,bl=parseFloat(inputs.block_length)||0.4,bh=parseFloat(inputs.block_height)||0.2;if(!L||!H)return{error:true};var brow=Math.ceil(L/bl),rows=Math.ceil(H/bh),blocks=Math.ceil(brow*rows*1.05),base=Math.ceil(H*50),gravel=+(L*0.3*0.3*1.5).toFixed(1),pipe=+(L*1.1).toFixed(1);return{blocks_needed:blocks,gravel_tonnes:gravel,base_depth_cm:base,drainage_pipe_m:pipe};",
  "example_inputs": {
    "wall_length": 6,
    "wall_height": 0.9,
    "block_length": 0.4,
    "block_height": 0.2
  },
