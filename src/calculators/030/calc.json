  ],
  "formula": "var A=parseFloat(inputs.area)||0,T=parseFloat(inputs.tam_pieza_cm)||60,J=parseFloat(inputs.ancho_junta_mm)||3,G=parseFloat(inputs.grosor_pieza_mm)||10;if(!A)return{error:true};var kg_m2=(2*J*G)/(T*10)*1.7*1.6,total=+(A*kg_m2*1.1).toFixed(2),sacos=Math.ceil(total/5);return{kg_m2:+kg_m2.toFixed(3),total_kg:total,sacos_5kg:sacos};",
  "outputs": [
