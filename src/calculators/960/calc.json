  "formula": "var edad=parseFloat(inputs.edad)||30,peso=parseFloat(inputs.peso_kg)||0,altura=parseFloat(inputs.altura_cm)||0,sexo=inputs.sexo||'mujer';if(!peso||!altura||altura<50)return{error:true};var bsa=+Math.sqrt((peso*altura)/3600).toFixed(2);var ibw=sexo=='hombre'?50+0.91*(altura-152.4):45.5+0.91*(altura-152.4);var abw=+(ibw+0.4*(peso-ibw)).toFixed(1);return{bsa:bsa+' m2',ideal_weight:+(ibw).toFixed(1),adjusted_weight:abw};",
