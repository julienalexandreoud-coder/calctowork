        "medio",
        "bueno"
      ]
    }
  ],
  "formula": "var A=parseFloat(inputs.area_m2)||0,H=parseFloat(inputs.altura_m)||2.7,orie={'norte':0.9,'sur':1.1,'este':1.0,'oeste':1.05},aisl={'deficiente':1.2,'medio':1.0,'bueno':0.85};if(!A)return{error:true};var vol=A*H,btu=+(vol*35*orie[inputs.orientacion]*aisl[inputs.aislamiento]).toFixed(0),kw=+(btu/3412).toFixed(2),frig=+(btu*0.252).toFixed(0),modelo=btu<=6000?'1x1':btu<=9000?'1x1 (9000)':btu<=12000?'1x1 (12000)':btu<=18000?'1x1.5 (18000)':'2x1+';return{vol_m3:+vol.toFixed(1),btu_necesarios:btu,kw_frio:kw,frigorias:frig,modelo_sugerido:modelo};",
  "outputs": [
    {
      "id": "vol_m3",
