  ],
  "formula": "var A=parseFloat(inputs.area)||0,tam=parseFloat(inputs.tam_malla_cm)||30;if(!A)return{error:true};var area_merma=+(A*1.10).toFixed(2),malla_m2=(tam/100)*(tam/100),mallas=Math.ceil(area_merma/malla_m2),adhesivo=+(area_merma*5).toFixed(1),lechada=+(area_merma*0.6).toFixed(1);return{area_merma_m2:area_merma,mallas_ud:mallas,adhesivo_kg:adhesivo,lechada_kg:lechada};",
  "outputs": [
    {
      "id": "area_merma_m2",
      "unit": "m² (+10%)",
      "highlight": true
    },
