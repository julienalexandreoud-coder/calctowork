  ],
  "formula": "var p=parseFloat(inputs.peso_kg)||0,e=parseFloat(inputs.ejercicio_hrs)||0,g=inputs.objetivo||'mantener';if(!p)return{error:true};var base=p*1.2*24;var act=e>0?e*300:0;var total=base+act;var obj={mantener:total,perder:total-500,ganar:total+500};return{calorias_mantenimiento:Math.round(obj[g]),proteinas:Math.round(p*1.6),grasas:Math.round(p*0.9),carbohidratos:Math.round((obj[g]-(p*1.6*4)-(p*0.9*9))/4)};",
