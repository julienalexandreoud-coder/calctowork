  "block_slug": "pavimentos",
  "inputs": [
    {
      "id": "area",
      "type": "number",
      "min": 1,
      "max": 500,
      "step": 0.5,
      "default": 25,
      "unit": "m²",
      "unit_options": [
        "m²",
        "ft²"
      ],
      "unit_category": "area"
    },
    {
      "id": "m2_por_caja",
      "type": "number",
      "min": 0.5,
      "max": 5,
      "step": 0.1,
      "default": 2.2,
      "unit": "m²/caja",
      "unit_options": [
        "m²/box"
      ],
      "unit_category": "area"
    },
    {
      "id": "colocacion",
      "type": "select",
      "default": "recto",
      "options": [
        "recto",
        "diagonal",
        "espiga"
      ]
    }
  ],
  "formula": "var A=parseFloat(inputs.area)||0,mxc=parseFloat(inputs.m2_por_caja)||2.2,diag=inputs.colocacion!=='recto';if(!A)return{error:true};var merma=diag?0.12:0.07,area_merma=+(A*(1+merma)).toFixed(2),cajas=Math.ceil(area_merma/mxc),barniz=+(A/10).toFixed(1),rodapie=+(Math.sqrt(A)*4).toFixed(1);return{area_merma_m2:area_merma,cajas_ud:cajas,barniz_litros:barniz,rodapie_ml:rodapie};",
  "outputs": [
    {
      "id": "area_merma_m2",
      "unit": "m² (con merma)",
      "highlight": true
    },
    {
      "id": "cajas_ud",
      "unit": "cajas"
    },
    {
      "id": "barniz_litros",
      "unit": "litros"
    },
    {
      "id": "rodapie_ml",
      "unit": "m.l."
    }
  ],
