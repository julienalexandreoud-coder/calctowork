      "min": 0,
      "max": 999999,
      "step": 100,
      "default": 2500,
      "unit": "EUR"
    },
    {
      "id": "anos",
      "type": "number",
      "min": 1,
      "max": 50,
      "step": 1,
      "default": 5,
      "unit": "yr",
      "unit_options": [
        "yr",
        "mo"
      ],
      "unit_category": "time"
    }
  ],
  "formula": "var inversion=parseFloat(inputs.inversion)||0,flujos=parseFloat(inputs.flujo_anual)||0,anos=parseFloat(inputs.anos)||0;if(!inversion||!flujos||!anos)return{error:true};var vpn=-inversion;for(var i=1;i<=anos;i++){vpn+=flujos/Math.pow(1.08,i);}var tir_approx=+(flujos/inversion).toFixed(4);var payback=Math.ceil(inversion/flujos);return{npv:+(vpn).toFixed(2),roi_annual:+(tir_approx*100).toFixed(2),payback_years:payback};",
  "outputs": [
    {
      "id": "npv",
      "unit": "EUR",
      "highlight": true
    },
    {
      "id": "roi_annual",
      "unit": "%",
      "highlight": false
    },
    {
      "id": "payback_years",
      "unit": "yr",
      "highlight": false
    }
  ],
