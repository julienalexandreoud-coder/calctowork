{
  "id": "1089",
  "slug": "humedad-relativa-rocio",
  "block": "clima",
  "formula": "var pr=parseFloat(inputs.punto_rocio)||0,t=parseFloat(inputs.temperatura)||0;var hr=100*(Math.exp(17.625*pr/(243.04+pr))/Math.exp(17.625*t/(243.04+t)));return{humedad_relativa:+hr.toFixed(1)};",
