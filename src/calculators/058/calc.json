{
  "id": "058",
  "slug": "dimensionado-conducto",
  "block": 6,
  "block_slug": "climatizacion",
  "inputs": [
    {
      "id": "caudal_m3h",
      "type": "number",
      "min": 10,
      "max": 100000,
      "step": 10,
      "default": 1000,
      "unit": "m³/h"
    },
    {
      "id": "perdida_carga_pa_m",
      "type": "number",
      "min": 0.5,
      "max": 5,
      "step": 0.1,
      "default": 1.5,
      "unit": "Pa/m"
    }
  ],
  "formula": "var Q=parseFloat(inputs.caudal_m3h)||0,dP=parseFloat(inputs.perdida_carga_pa_m)||1.5;if(!Q)return{error:true};var rho=1.2,v=Math.pow(dP*2/rho*0.5,0.5)*2,A_m2=Q/3600/v,D_mm=+(Math.sqrt(4*A_m2/Math.PI)*1000).toFixed(0),D_norm=D_mm<=100?100:D_mm<=125?125:D_mm<=160?160:D_mm<=200?200:D_mm<=250?250:315;return{velocidad_ms:+v.toFixed(2),diametro_mm:D_norm,area_m2:+A_m2.toFixed(4)};",
  "outputs": [
    {
      "id": "velocidad_ms",
      "unit": "m/s"
    },
    {
      "id": "diametro_mm",
      "unit": "mm Ã˜",
      "highlight": true
    },
    {
      "id": "area_m2",
      "unit": "m² sección"
    }
  ],
