      "type": "number",
      "min": 5,
      "max": 20,
      "step": 0.5,
      "default": 10,
      "unit": "cm",
      "unit_category": "length"
    },
    {
      "id": "gap_between",
      "type": "number",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "default": 5,
      "unit": "cm",
      "unit_category": "length"
    },
    {
      "id": "post_spacing",
      "type": "number",
      "min": 1,
      "max": 5,
      "step": 0.1,
      "default": 2.4,
      "unit": "m",
      "unit_category": "length"
    }
  ],
  "outputs": [
    {
      "id": "pickets_needed",
      "unit": "pcs",
      "highlight": true
    },
    {
      "id": "posts_needed",
      "unit": "posts"
    },
    {
      "id": "rails_needed",
      "unit": "rails"
    },
    {
      "id": "total_linear_meters",
      "unit": "m"
    }
  ],
  "formula": "var fl=parseFloat(inputs.fence_length)||0,pw=parseFloat(inputs.picket_width)||10,gb=parseFloat(inputs.gap_between)||5,ps=parseFloat(inputs.post_spacing)||2.4;if(!fl)return{error:true};var spp=(pw+gb)/100,pickets=Math.ceil(fl/spp),posts=Math.ceil(fl/ps)+1,rails=(posts-1)*2,tlm=+(pickets*(pw/100)).toFixed(1);return{pickets_needed:pickets,posts_needed:posts,rails_needed:rails,total_linear_meters:tlm};",
