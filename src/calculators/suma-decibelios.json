  "formula": "var db1=parseFloat(inputs.db1)||0;var db2=parseFloat(inputs.db2)||0;var p1=Math.pow(10,db1/10);var p2=Math.pow(10,db2/10);var total=10*Math.log10(p1+p2);return{total:total.toFixed(2)};",
