{
  "id": "1053",
  "slug": "suma-geometrica",
  "block": "matematicas",
  "formula": "var a1=parseFloat(inputs.a1)||1,r=parseFloat(inputs.r)||1,n=parseFloat(inputs.n)||1;var suma;if(Math.abs(r-1)<1e-10)suma=a1*n;else suma=a1*(1-Math.pow(r,n))/(1-r);return{suma:+suma.toFixed(2),termino_n:+(a1*Math.pow(r,n-1)).toFixed(2)};",
  "inputs": [
    {
      "id": "a1",
      "type": "number",
      "default": 1,
      "unit": ""
    },
    {
      "id": "r",
      "type": "number",
      "default": 2,
      "unit": ""
    },
    {
      "id": "n",
      "type": "number",
      "default": 10,
      "min": 1,
      "unit": ""
    }
  ],
  "outputs": [
    {
      "id": "suma",
      "unit": ""
    },
    {
      "id": "termino_n",
      "unit": ""
    }
  ],
