  "inputs": [
    {
      "id": "desviacion",
      "type": "number",
      "min": 0.001,
      "max": 1000000000000,
      "step": "any",
      "default": 10,
      "unit": ""
    },
    {
      "id": "media",
      "type": "number",
      "min": 0,
      "max": 1000000000000,
      "step": "any",
      "default": 50,
      "unit": ""
    }
  ],
  "formula": "var s=parseFloat(inputs.desviacion)||0,m=parseFloat(inputs.media)||0;if(!m)return{error:true};return{cv_porcentaje:+(s/m*100).toFixed(2)};",
  "outputs": [
    {
      "id": "cv_porcentaje",
      "unit": "%",
      "highlight": true
    }
  ],
