  "formula": "var d=parseFloat(inputs.distancia)||0,t=parseFloat(inputs.tiempo)||0;if(!t)return{error:true};var v=d/t;return{velocidad_ms:+v.toFixed(4),velocidad_kmh:+(v*3.6).toFixed(2),velocidad_mph:+(v*2.237).toFixed(2)};",
  "outputs": [
