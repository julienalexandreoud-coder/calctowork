  "formula": "var x1=parseFloat(inputs.x1)||0,y1=parseFloat(inputs.y1)||0,x2=parseFloat(inputs.x2)||0,y2=parseFloat(inputs.y2)||0;if(x1==x2)return{error:true};var m=+(y2-y1)/(x2-x1),b=+(y1-m*x1).toFixed(2),dist=+Math.sqrt((x2-x1)**2+(y2-y1)**2).toFixed(2);return{slope:+(m).toFixed(4),intercept:b,distance:dist,angle:+(Math.atan(m)*180/Math.PI).toFixed(2)};",
