  "formula": "var inc=parseFloat(inputs.income)||0;var dr=(parseFloat(inputs.debt_ratio)||0)/100;var r=(parseFloat(inputs.rate)||0)/1200;var n=(parseFloat(inputs.years)||0)*12;var max_payment=inc*dr;var max_loan=r>0?max_payment*(1-Math.pow(1+r,-n))/r:max_payment*n;return{max_loan:max_loan.toFixed(2)};",
  "outputs": [
