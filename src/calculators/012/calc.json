  "formula": "var L=parseFloat(inputs.largo)||0,H=parseFloat(inputs.alto)||0,huecos=parseFloat(inputs.descontar_huecos)||0;if(!L||!H)return{error:true};var area_bruta=L*H,area_neta=Math.max(0,area_bruta-huecos),ladrillos=Math.ceil(area_neta*55*1.07),mortero=+(area_neta*20).toFixed(1),junta=+(area_neta*0.5).toFixed(1);return{area_bruta:+area_bruta.toFixed(2),area_neta:+area_neta.toFixed(2),ladrillos_ud:ladrillos,mortero_kg:mortero,lechada_kg:junta};",
