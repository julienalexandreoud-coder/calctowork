      "type": "number",
      "min": 0,
      "max": 99999,
      "step": 10,
      "default": 300,
      "unit": "EUR"
    }
  ],
  "formula": "var deuda=parseFloat(inputs.deuda_total)||0,tasa=parseFloat(inputs.tasa_anual)||0,pago=parseFloat(inputs.pago_mensual)||0;if(!deuda||!tasa||!pago)return{error:true};var r=tasa/1200,balance=deuda,meses=0,total_interes=0;while(balance>0&&meses<600){var interes_mes=balance*r;total_interes+=interes_mes;var principal=pago-interes_mes;if(principal<=0)return{error:true};balance-=principal;meses++;}return{months_to_payoff:meses,total_interest:+(total_interes).toFixed(2),total_paid:+(deuda+total_interes).toFixed(2)};",
  "outputs": [
    {
      "id": "months_to_payoff",
      "unit": "",
      "highlight": true
    },
