{
  "id": "1029",
  "slug": "evapotranspiracion",
  "block": 1,
  "block_slug": "clima",
  "inputs": [
    {
      "id": "temp",
      "type": "number",
      "step": "any",
      "default": 25,
      "unit": "°C",
      "unit_options": [
        "°C",
        "°F"
      ],
      "unit_category": "temperature"
    },
    {
      "id": "rh",
      "type": "number",
      "step": "any",
      "default": 50,
      "unit": "%",
      "unit_options": [
        "%"
      ],
      "unit_category": "ratio"
    },
    {
      "id": "wind",
      "type": "number",
      "step": "any",
      "default": 2,
      "unit": "m/s",
      "unit_options": [
        "m/s",
        "km/h"
      ],
      "unit_category": "speed"
    }
  ],
  "formula": "var t=parseFloat(inputs.temp)||0;var rh=parseFloat(inputs.rh)||0;var w=parseFloat(inputs.wind)||0;var et=0.0023*(t+17.8)*Math.pow(rh,0.5)*w;return{et:et.toFixed(2)};",
  "outputs": [
    {
      "id": "et",
      "unit": "mm/d"
    }
  ],
