  "formula": "var A=parseFloat(inputs.area_m2)||0,sg=parseFloat(inputs.separacion_goteros_cm)||30,sl=parseFloat(inputs.separacion_lineas_m)||0.5;if(!A)return{error:true};var lineas_m=+(A/sl).toFixed(1),goteros=Math.ceil((A/(sl*sg/100))),tuberia_m=+(lineas_m*1.15).toFixed(1),programador=1;return{lineas_tuberia_m:tuberia_m,goteros_ud:goteros,sectores:Math.ceil(A/500)};",
