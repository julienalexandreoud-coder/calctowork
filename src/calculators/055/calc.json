      "min": 0.5,
      "max": 10,
      "step": 0.5,
      "default": 0.8,
      "unit": "ren/h"
    }
  ],
  "formula": "var A=parseFloat(inputs.area_m2)||0,H=parseFloat(inputs.altura_m)||2.7,R=parseFloat(inputs.renovaciones_hora)||0.8;if(!A)return{error:true};var vol=A*H,m3h=+(vol*R).toFixed(1),ls=+(m3h/3.6).toFixed(1),kw_fan=+(m3h*0.0003).toFixed(2);return{vol_m3:+vol.toFixed(1),caudal_m3h:m3h,caudal_ls:ls,potencia_kw:kw_fan};",
  "outputs": [
    {
      "id": "vol_m3",
      "unit": "m³"
    },
    {
      "id": "caudal_m3h",
      "unit": "m³/h",
      "highlight": true
    },
    {
      "id": "caudal_ls",
      "unit": "L/s"
    },
    {
      "id": "potencia_kw",
      "unit": "kW ventilador"
    }
  ],
