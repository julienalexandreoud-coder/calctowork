  "formula": "var A=parseFloat(inputs.area_m2)||0,H=parseFloat(inputs.altura_m)||2.7,coef={'interior':0.04,'exterior_norte':0.065,'exterior_sur':0.05,'sotano':0.07};if(!A)return{error:true};var vol=A*H,w_necesarios=+(vol*coef[inputs.orientacion]*1000).toFixed(0),elementos=Math.ceil(w_necesarios/175),radiadores=Math.ceil(elementos/12);return{vol_m3:+vol.toFixed(1),w_necesarios:w_necesarios,elementos_ud:elementos,radiadores_ud:radiadores};",
