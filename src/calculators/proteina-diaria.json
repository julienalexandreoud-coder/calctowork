  "formula": "var p=parseFloat(inputs.peso)||70,obj=inputs.objetivo||\"mantener\";var f=1.2;if(obj==\"ganar_musculo\")f=1.6;else if(obj==\"perder_peso\")f=2.0;return{proteina_min:+(p*0.8).toFixed(1),proteina_max:+(p*2.2).toFixed(1),proteina_recomendada:+(p*f).toFixed(1)};",
