      "default": 6,
      "unit": "%",
      "unit_options": [
        "%"
      ],
      "unit_category": "percentage"
    }
  ],
  "formula": "var cost=parseFloat(inputs.cost)||0;var y=parseFloat(inputs.years)||1;var r=(parseFloat(inputs.rate)||0)/100;var n=y*12;var monthly=r>0?cost*r/12/(Math.pow(1+r/12,n)-1):cost/n;return{monthly:monthly.toFixed(2)};",
  "outputs": [
    {
      "id": "monthly",
      "unit": "USD"
    }
  ],
