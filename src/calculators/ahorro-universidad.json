  "inputs": [
    {
      "id": "cost",
      "type": "number",
      "step": "any",
      "default": 100000,
      "unit": "USD",
      "unit_options": [
        "USD",
        "EUR",
        "GBP"
      ],
      "unit_category": "currency"
    },
    {
      "id": "years",
      "type": "number",
      "step": 1,
      "default": 18,
      "unit": "yr",
      "unit_options": [
        "yr"
      ],
      "unit_category": "time"
    },
    {
      "id": "rate",
      "type": "number",
      "step": "any",
      "default": 6,
      "unit": "%",
      "unit_options": [
        "%"
      ],
      "unit_category": "percentage"
    }
  ],
  "formula": "var cost=parseFloat(inputs.cost)||0;var y=parseFloat(inputs.years)||1;var r=(parseFloat(inputs.rate)||0)/100;var n=y*12;var monthly=r>0?cost*r/12/(Math.pow(1+r/12,n)-1):cost/n;return{monthly:monthly.toFixed(2)};",
  "outputs": [
    {
      "id": "monthly",
      "unit": "USD"
    }
  ],
