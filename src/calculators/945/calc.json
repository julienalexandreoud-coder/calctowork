  ],
  "formula": "var original=parseFloat(inputs.precio_original)||0,d1=parseFloat(inputs.descuento1)||0,d2=parseFloat(inputs.descuento2)||0;if(!original)return{error:true};var p1=original*(1-d1/100);var final=p1*(1-d2/100);var ahorro=original-final;return{final_price:+(final).toFixed(2),total_savings:+(ahorro).toFixed(2),savings_pct:+(ahorro/original*100).toFixed(1)};",
  "outputs": [
    {
      "id": "final_price",
