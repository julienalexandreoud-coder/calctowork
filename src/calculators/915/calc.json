{
  "id": "915",
  "slug": "prime-factorization",
  "block": 13,
  "block_slug": "matematicas",
  "inputs": [
    {
      "id": "numero",
      "type": "number",
      "min": 2,
      "max": 999999,
      "step": 1,
      "default": 60,
      "unit": ""
    }
  ],
  "formula": "var n=parseInt(inputs.numero)||0;if(n<2)return{error:true};var temp=n,factors=[],d=2;while(d*d<=temp){while(temp%d==0){factors.push(d);temp/=d;}d++;}if(temp>1)factors.push(temp);return{factors:factors.join(' x '),count:factors.length,sum:factors.reduce((a,b)=>a+b,0),is_prime:factors.length==1};",
  "outputs": [
    {
      "id": "factors",
      "unit": "",
      "highlight": true
    },
    {
      "id": "count",
      "unit": "",
      "highlight": false
    },
    {
      "id": "sum",
      "unit": "",
      "highlight": false
    },
    {
      "id": "is_prime",
      "unit": "",
      "highlight": false
    }
  ],
