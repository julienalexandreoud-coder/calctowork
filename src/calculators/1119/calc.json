{
  "id": "1119",
  "slug": "landscape-rock-calculator",
  "block": 1,
  "block_slug": "estructuras",
  "inputs": [
    {
      "id": "area_length",
      "type": "number",
      "min": 0.1,
      "max": 100,
      "step": 0.1,
      "default": 5,
      "unit": "m",
      "unit_category": "length"
    },
    {
      "id": "area_width",
      "type": "number",
      "min": 0.1,
      "max": 50,
      "step": 0.1,
      "default": 3,
      "unit": "m",
      "unit_category": "length"
    },
    {
      "id": "depth_cm",
      "type": "number",
      "min": 2,
      "max": 30,
      "step": 1,
      "default": 5,
      "unit": "cm",
      "unit_category": "length"
    },
    {
      "id": "rock_type",
      "type": "select",
      "options": [
        {
          "value": "gravel",
          "label": "Gravel (1.6 t/m³)"
        },
        {
          "value": "crushed",
          "label": "Crushed Stone (1.7 t/m³)"
        },
        {
          "value": "river",
          "label": "River Rock (1.5 t/m³)"
        },
        {
          "value": "decomposed",
          "label": "Decomposed Granite (1.8 t/m³)"
        }
      ],
      "default": "gravel"
    }
  ],
  "outputs": [
    {
      "id": "area_m2",
      "unit": "m²",
      "highlight": true
    },
    {
      "id": "volume_m3",
      "unit": "m³"
    },
    {
      "id": "tonnes_needed",
      "unit": "t"
    },
    {
      "id": "cubic_yards",
      "unit": "yd³"
    }
  ],
  "formula": "var L=parseFloat(inputs.area_length)||0,W=parseFloat(inputs.area_width)||0,d=parseFloat(inputs.depth_cm)||8,rt=inputs.rock_type||'pea_gravel';if(!L||!W||!d)return{error:true};var area=+(L*W).toFixed(2),vol=+(L*W*(d/100)).toFixed(3),den={'pea_gravel':1.5,'crushed_granite':1.7,'river_rock':1.5,'lava_rock':0.8,'limestone':1.6},tonnes=+(vol*(den[rt]||1.5)).toFixed(2),yards=+(vol*1.308).toFixed(2);return{area_m2:area,volume_m3:vol,tonnes_needed:tonnes,cubic_yards:yards};",
  "example_inputs": {
    "area_length": 6,
    "area_width": 4,
    "depth_cm": 8,
    "rock_type": 1
  },
