  "formula": "var A=parseFloat(inputs.area)||0,tam=parseFloat(inputs.tam_pieza_cm)||30,pxc=parseFloat(inputs.piezas_por_caja)||10;if(!A)return{error:true};var area_merma=+(A*1.15).toFixed(2),pieza_m2=(tam/100)*(tam/100),piezas=Math.ceil(area_merma/pieza_m2),cajas=Math.ceil(piezas/pxc),adhesivo=+(area_merma*4).toFixed(1),lechada=+(area_merma*0.4).toFixed(1);return{area_merma_m2:area_merma,piezas_ud:piezas,cajas_ud:cajas,adhesivo_kg:adhesivo,lechada_kg:lechada};",
