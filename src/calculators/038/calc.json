  "formula": "var A=parseFloat(inputs.area_m2)||0,sep=parseFloat(inputs.separacion_cm)||20,cmax=parseFloat(inputs.circuitos_max_m)||80;if(!A)return{error:true};var ml_tubo=+(A*(100/sep)*1.1).toFixed(1),circuitos=Math.ceil(ml_tubo/cmax),colectores=Math.ceil(circuitos/8),mortero_kg=+(A*80).toFixed(0);return{ml_tubo:ml_tubo,circuitos:circuitos,colectores_ud:colectores,mortero_autonivelante_kg:mortero_kg};",
