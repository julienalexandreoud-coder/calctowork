  "formula": "var c=parseFloat(inputs.celsius)||0;var f=+(c*9/5+32).toFixed(2),k=+(c+273.15).toFixed(2),r=+(c*9/5+491.67).toFixed(2);return{fahrenheit:f,kelvin:k,rankine:r};",
  "outputs": [
