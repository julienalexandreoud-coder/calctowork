    {
      "id": "linear_meters",
      "unit": "m"
    },
    {
      "id": "boards_needed",
      "unit": "boards"
    },
    {
      "id": "returns_needed",
      "unit": "pcs"
    }
  ],
  "formula": "var P=parseFloat(inputs.room_perimeter)||0,dw=parseFloat(inputs.door_width)||0.9,dc=parseFloat(inputs.doors_count)||1,bl=parseFloat(inputs.board_length)||2.4;if(!P)return{error:true};var net=+(P-(dc*dw)).toFixed(2),lm=+(net*1.10).toFixed(1),boards=Math.ceil(lm/bl),returns=dc*2;return{net_perimeter_m:net,linear_meters:lm,boards_needed:boards,returns_needed:returns};",
