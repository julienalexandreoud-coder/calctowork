  "formula": "var vid=parseFloat(inputs.hours_video)||0;var mus=parseFloat(inputs.hours_music)||0;var web=parseFloat(inputs.hours_web)||0;var total=vid*3+mus*0.1+web*0.05;return{total_gb:total.toFixed(2)};",
