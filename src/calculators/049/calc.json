{
  "id": "049",
  "slug": "baterias-autonomia",
  "block": 5,
  "block_slug": "electricidad",
  "inputs": [
    {
      "id": "consumo_diario_kwh",
      "type": "number",
      "min": 0.5,
      "max": 200,
      "step": 0.5,
      "default": 10,
      "unit": "kWh/día"
    },
    {
      "id": "dias_autonomia",
      "type": "number",
      "min": 0.5,
      "max": 5,
      "step": 0.5,
      "default": 1,
      "unit": "días"
    },
    {
      "id": "capacidad_bateria_kwh",
      "type": "number",
      "min": 2,
      "max": 20,
      "step": 0.5,
      "default": 5,
      "unit": "kWh/bat"
    }
  ],
  "formula": "var C=parseFloat(inputs.consumo_diario_kwh)||0,D=parseFloat(inputs.dias_autonomia)||1,CB=parseFloat(inputs.capacidad_bateria_kwh)||5;if(!C)return{error:true};var kwh_nec=+(C*D/0.8).toFixed(2),baterias=Math.ceil(kwh_nec/CB),kwh_inst=+(baterias*CB).toFixed(1);return{kwh_necesario:kwh_nec,baterias_ud:baterias,kwh_instalado:kwh_inst};",
  "outputs": [
    {
      "id": "kwh_necesario",
      "unit": "kWh necesario"
    },
    {
      "id": "baterias_ud",
      "unit": "baterías",
      "highlight": true
    },
    {
      "id": "kwh_instalado",
      "unit": "kWh instalado"
    }
  ],
  "related": [
    "048",
    "052",
    "047",
    "043"
  ],
