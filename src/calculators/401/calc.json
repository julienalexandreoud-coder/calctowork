  "formula": "var P=parseFloat(inputs.peso_kg)||0,H=parseFloat(inputs.altura_cm)||0,E=parseFloat(inputs.edad)||0,G=parseFloat(inputs.genero)||1,A=parseFloat(inputs.nivel_actividad)||3;if(!P||!H||!E)return{error:true};var bmr=G<=1?(10*P+6.25*H-5*E+5):(10*P+6.25*H-5*E-161);var fact=[1.2,1.375,1.55,1.725,1.9][Math.min(4,Math.max(0,Math.round(A)-1))];var tdee=+(bmr*fact).toFixed(0),bajar=+(tdee-500).toFixed(0),subir=+(tdee+500).toFixed(0);return{calorias_mantenimiento:tdee,para_adelgazar:bajar,para_ganar_peso:subir,metabolismo_basal:+bmr.toFixed(0)};",
