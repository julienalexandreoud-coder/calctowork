  "inputs": [
    {
      "id": "ahorro_mensual",
      "type": "number",
      "min": 0,
      "max": 99999,
      "step": 10,
      "default": 500,
      "unit": "EUR"
    },
    {
      "id": "tasa_anual",
      "type": "number",
      "min": 0,
      "max": 20,
      "step": 0.01,
      "default": 7,
      "unit": "%",
      "unit_options": [
