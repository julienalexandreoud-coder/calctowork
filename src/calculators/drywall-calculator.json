{
  "id": "1115",
  "slug": "drywall-calculator",
  "block": 2,
  "block_slug": "mamposteria",
  "inputs": [
    {
      "id": "wall_length",
      "type": "number",
      "min": 0.1,
      "max": 100,
      "step": 0.1,
      "default": 5,
      "unit": "m",
      "unit_category": "length"
    },
    {
      "id": "wall_height",
      "type": "number",
      "min": 1,
      "max": 10,
      "step": 0.1,
      "default": 2.7,
      "unit": "m",
      "unit_category": "length"
    },
    {
      "id": "sheet_size",
      "type": "select",
      "options": [
        {
          "value": "1.2x2.4",
          "label": "1.2×2.4m (4×8 ft)"
        },
        {
          "value": "1.2x3.0",
          "label": "1.2×3.0m (4×10 ft)"
        },
        {
          "value": "1.2x3.6",
          "label": "1.2×3.6m (4×12 ft)"
        }
      ],
      "default": "1.2x2.4"
    },
    {
      "id": "layers",
      "type": "number",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1,
      "unit": "pcs",
      "unit_category": "count"
    }
  ],
  "outputs": [
    {
      "id": "wall_area_m2",
      "unit": "m²",
      "highlight": true
    },
    {
      "id": "sheets_needed",
      "unit": "sheets"
    },
    {
      "id": "mud_kg",
      "unit": "kg"
    },
    {
      "id": "tape_meters",
      "unit": "m"
    },
    {
      "id": "screws_count",
      "unit": "pcs"
    }
  ],
  "formula": "var L=parseFloat(inputs.wall_length)||0,H=parseFloat(inputs.wall_height)||0,ss=inputs.sheet_size||'4x8',layers=parseFloat(inputs.layers)||1;if(!L||!H)return{error:true};var area=+(L*H*layers).toFixed(2),sa={'4x8':2.97,'4x12':4.46,'4x10':3.72},sheet_area=sa[ss]||2.97,sheets=Math.ceil(area/sheet_area*1.10),mud=+(area*0.5).toFixed(1),tape=+(area*0.9).toFixed(1),screws=Math.ceil(area*8);return{wall_area_m2:+(L*H).toFixed(2),sheets_needed:sheets,mud_kg:mud,tape_meters:tape,screws_count:screws};",
  "example_inputs": {
    "wall_length": 6,
    "wall_height": 2.7,
    "sheet_size": 2.88,
    "layers": 1
  },
