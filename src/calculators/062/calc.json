{
  "id": "062",
  "slug": "puertas-paso",
  "block": 7,
  "block_slug": "carpinteria",
  "inputs": [
    {
      "id": "num_puertas",
      "type": "number",
      "min": 1,
      "max": 50,
      "step": 1,
      "default": 8,
      "unit": "ud",
      "unit_options": [
        "ud"
      ],
      "unit_category": "count"
    },
    {
      "id": "ancho_m",
      "type": "number",
      "min": 0.6,
      "max": 1.2,
      "step": 0.05,
      "default": 0.82,
      "unit": "m",
      "unit_options": [
        "m",
        "cm",
        "mm",
        "ft",
        "in"
      ],
      "unit_category": "length"
    },
    {
      "id": "alto_m",
      "type": "number",
      "min": 1.8,
      "max": 2.5,
      "step": 0.05,
      "default": 2.03,
      "unit": "m",
      "unit_options": [
        "m",
        "cm",
        "mm",
        "ft",
        "in"
      ],
      "unit_category": "length"
    }
  ],
  "formula": "var n=parseFloat(inputs.num_puertas)||0,W=parseFloat(inputs.ancho_m)||0.825,H=parseFloat(inputs.alto_m)||2.03;if(!n)return{error:true};var m2_ud=+(W*H).toFixed(2),m2_tot=+(m2_ud*n).toFixed(2),marcos=n,tiradores=n*2,bisagras=+(Math.ceil(H/0.3)*n).toFixed(0),perimetro=+(2*(W+H)*1.05*n).toFixed(1),cerco=+(perimetro*0.07).toFixed(2);return{m2_hoja:m2_ud,m2_total_hojas:m2_tot,marcos_ud:marcos,tiradores_ud:tiradores,bisagras_ud:bisagras,perimetro_ml:perimetro,cerco_m2:+cerco.toFixed(2)};",
  "outputs": [
    {
      "id": "m2_hoja",
      "unit": "m²/hoja"
    },
    {
      "id": "m2_total_hojas",
      "unit": "m² total",
      "highlight": true
    },
    {
      "id": "marcos_ud",
      "unit": "marcos"
    },
    {
      "id": "tiradores_ud",
      "unit": "tiradores"
    },
    {
      "id": "bisagras_ud",
      "unit": "bisagras"
    },
    {
      "id": "perimetro_ml",
      "unit": "m.l. cerco"
    },
    {
      "id": "cerco_m2",
      "unit": "m² cerco"
    }
  ],
