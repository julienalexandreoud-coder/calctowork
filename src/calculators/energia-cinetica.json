      "default": 15,
      "unit": ""
    }
  ],
  "formula": "var m=parseFloat(inputs.masa)||0,v=parseFloat(inputs.velocidad)||0;var ke=.5*m*v*v;return{energia_j:+ke.toFixed(4),energia_kj:+(ke/1000).toFixed(4),velocidad_kmh:+(v*3.6).toFixed(2)};",
