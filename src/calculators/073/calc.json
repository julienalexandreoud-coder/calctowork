  "formula": "var L=parseFloat(inputs.longitud_pared_m)||0,H=parseFloat(inputs.altura_m)||2.6,Wr=parseFloat(inputs.ancho_rollo_m)||0.53,Lr=parseFloat(inputs.longitud_rollo_m)||10;if(!L)return{error:true};var tiras_rollo=Math.floor(Lr/H),m2_pared=+(L*H).toFixed(2),tiras_nec=Math.ceil(L/Wr),rollos=Math.ceil(tiras_nec/tiras_rollo*1.1);return{m2_pared:m2_pared,tiras_nec:tiras_nec,rollos_ud:rollos};",
