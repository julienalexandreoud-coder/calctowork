{
  "id": "057",
  "slug": "calculo-cop-eer",
  "block": 6,
  "block_slug": "climatizacion",
  "inputs": [
    {
      "id": "potencia_util_kw",
      "type": "number",
      "min": 0.5,
      "max": 200,
      "step": 0.5,
      "default": 3.5,
      "unit": "kW útil"
    },
    {
      "id": "potencia_elec_kw",
      "type": "number",
      "min": 0.1,
      "max": 100,
      "step": 0.1,
      "default": 1,
      "unit": "kW eléctrico"
    }
  ],
  "formula": "var Qu=parseFloat(inputs.potencia_util_kw)||0,Qe=parseFloat(inputs.potencia_elec_kw)||0;if(!Qu||!Qe)return{error:true};var cop=+(Qu/Qe).toFixed(2),eer=cop,clase=cop>=5?'A+++':cop>=4?'A++':cop>=3.5?'A+':cop>=3?'A':'B';return{cop:cop,eer:eer,clase_eficiencia:clase,ahorro_vs_resistencia_pct:+((1-1/cop)*100).toFixed(1)};",
  "outputs": [
    {
      "id": "cop",
      "unit": "COP",
      "highlight": true
    },
    {
      "id": "eer",
      "unit": "EER"
    },
    {
      "id": "clase_eficiencia",
      "unit": "Clase energética"
    },
    {
      "id": "ahorro_vs_resistencia_pct",
      "unit": "% ahorro vs eléctrico directo"
    }
  ],
  "related": [
    "056",
    "053",
    "036",
    "054"
  ],
  "example_inputs": {
    "potencia_util_kw": 3.5,
    "potencia_elec_kw": 1
  },
  "comparison_presets": [
    {
      "_label": "Small room",
      "potencia_util_kw": 1.75,
      "potencia_elec_kw": 0.5
    },
    {
      "_label": "Medium room",
      "potencia_util_kw": 2.625,
      "potencia_elec_kw": 0.75
    },
    {
      "_label": "Large room",
      "potencia_util_kw": 3.5,
      "potencia_elec_kw": 1
    },
    {
      "_label": "Office",
      "potencia_util_kw": 5.25,
      "potencia_elec_kw": 1.5
    },
    {
      "_label": "Warehouse",
      "potencia_util_kw": 7,
      "potencia_elec_kw": 2
    }
  ]
}