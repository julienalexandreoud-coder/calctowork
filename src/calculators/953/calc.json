  "formula": "var edad=parseFloat(inputs.edad)||30,peso=parseFloat(inputs.peso_kg)||70,fc_reposo=parseFloat(inputs.fc_reposo)||60,duracion=parseFloat(inputs.duracion_min)||30;if(!edad||!peso)return{error:true};var fc_max=220-edad;var vo2=+(15.3*(fc_max/fc_reposo)).toFixed(1);var cal=+(0.0175*vo2*peso*duracion).toFixed(0);return{vo2_max:vo2,calories_burned:cal,fitness_level:vo2>50?'Excellent':vo2>40?'Good':vo2>30?'Average':'Below average'};",
