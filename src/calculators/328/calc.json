  ],
  "formula": "var pmt=parseFloat(inputs.pmt)||0;var r=(parseFloat(inputs.rate)||0)/100;var n=parseFloat(inputs.n)||0;var pv=r>0?pmt*((1-Math.pow(1+r,-n))/r):pmt*n;return{pv:pv.toFixed(2)};",
