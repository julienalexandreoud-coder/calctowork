{
  "id": "952",
  "slug": "running-pace-predictor",
  "block": 16,
  "block_slug": "deportes",
  "inputs": [
    {
      "id": "distancia_km",
      "type": "number",
      "min": 0.1,
      "max": 100,
      "step": 0.1,
      "default": 5,
      "unit": "km",
