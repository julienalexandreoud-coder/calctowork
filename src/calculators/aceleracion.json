      "type": "number",
      "min": 0.001,
      "max": 1000000000000,
      "step": "any",
      "default": 5,
      "unit": ""
    }
  ],
  "formula": "var vi=parseFloat(inputs.vi)||0,vf=parseFloat(inputs.vf)||0,t=parseFloat(inputs.tiempo)||0;if(!t)return{error:true};var a=(vf-vi)/t;return{aceleracion:+a.toFixed(4),aceleracion_g:+(a/9.80665).toFixed(4)};",
