  "inputs": [
    {
      "id": "vi",
      "type": "number",
      "min": 0,
      "max": 1000000000000,
      "step": "any",
      "default": 0,
      "unit": ""
    },
    {
      "id": "vf",
      "type": "number",
      "min": 0,
      "max": 1000000000000,
      "step": "any",
      "default": 30,
      "unit": ""
    },
    {
      "id": "tiempo",
      "type": "number",
      "min": 0.001,
      "max": 1000000000000,
      "step": "any",
      "default": 5,
      "unit": ""
    }
  ],
  "formula": "var vi=parseFloat(inputs.vi)||0,vf=parseFloat(inputs.vf)||0,t=parseFloat(inputs.tiempo)||0;if(!t)return{error:true};var a=(vf-vi)/t;return{aceleracion:+a.toFixed(4),aceleracion_g:+(a/9.80665).toFixed(4)};",
  "outputs": [
    {
      "id": "aceleracion",
      "unit": "m/s²",
      "highlight": true
    },
    {
      "id": "aceleracion_g",
      "unit": "g"
    }
  ],
