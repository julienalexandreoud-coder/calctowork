  ],
  "formula": "var precio=parseFloat(inputs.precio_casa)||0,entrada=parseFloat(inputs.entrada_pct)||20,tasa=parseFloat(inputs.tasa_anual)||0,anos=parseFloat(inputs.anos)||30;if(!precio||!tasa||!anos)return{error:true};var prestamo=precio*(1-entrada/100),r=tasa/1200,n=anos*12,pmt=prestamo*r/(1-Math.pow(1+r,-n));var total=+(pmt*n).toFixed(2),interes=+(total-prestamo).toFixed(2);return{monthly_payment:+(pmt).toFixed(2),loan_amount:+(prestamo).toFixed(2),total_paid:total,total_interest:interes,interest_ratio:+(interes/total*100).toFixed(1)};",
