      "type": "number",
      "min": 0.8,
      "max": 0.99,
      "step": 0.01,
      "default": 0.95,
      "unit": ""
    }
  ],
  "formula": "var n=parseInt(inputs.tamano_muestra)||0,p=parseFloat(inputs.proporcion)||0.5,e=parseFloat(inputs.margen_error)||0.05,conf=parseFloat(inputs.confianza)||0.95;if(!n)return{error:true};var z={0.9:1.645,0.95:1.96,0.99:2.576};var zv=z[conf]||1.96;var se=+Math.sqrt(p*(1-p)/n).toFixed(4);var me=+(zv*se).toFixed(4);var lower=+(p-me).toFixed(4),upper=+(p+me).toFixed(4);return{sample_size:n,standard_error:se,margin_of_error:me,ci_lower:lower,ci_upper:upper};",
  "outputs": [
    {
      "id": "sample_size",
      "unit": ""
    },
    {
      "id": "standard_error",
      "unit": "",
      "highlight": true
    },
    {
      "id": "margin_of_error",
      "unit": "",
      "highlight": false
    },
