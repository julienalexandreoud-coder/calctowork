<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {{ ga4_head | safe }}
  <title>{{ page_title }} | CalcToWork</title>
  <meta name="description" content="{{ page_description }}">
  <meta name="robots" content="index, follow">
  <meta name="theme-color" content="#f97316">
  <link rel="canonical" href="{{ site_base_url }}/{{ lang }}/{{ page_slug }}/">

  {% for alt_lang in all_langs %}
  <link rel="alternate" hreflang="{{ alt_lang }}" href="{{ site_base_url }}/{{ alt_lang }}/{{ page_slug }}/">
  {% endfor %}
  <link rel="alternate" hreflang="x-default" href="{{ site_base_url }}/en/{{ page_slug }}/">

  <meta property="og:title" content="{{ page_title }} | CalcToWork">
  <meta property="og:description" content="{{ page_description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site_base_url }}/{{ lang }}/{{ page_slug }}/">
  <meta property="og:site_name" content="CalcToWork">
  <meta property="og:image" content="{{ site_base_url }}/og/default.png">
  <meta property="og:locale" content="{{ 'es_ES' if lang=='es' else 'en_US' if lang=='en' else 'fr_FR' if lang=='fr' else 'pt_BR' if lang=='pt' else 'de_DE' if lang=='de' else 'it_IT' }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ page_title }} | CalcToWork">
  <meta name="twitter:description" content="{{ page_description }}">

  <meta name="google-site-verification" content="IODnwsJUNWyjMxqiXR1jY6lM-4IR7r-n0rgZ6OGMdLg">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/x-icon" sizes="32x32" href="/favicon.ico">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="preconnect" href="https://pagead2.googlesyndication.com">
  <link rel="preconnect" href="https://www.googletagmanager.com">
  <link rel="stylesheet" href="/css/styles.css">
  <script>if(localStorage.getItem('ctw-theme')==='dark')document.documentElement.setAttribute('data-theme','dark');</script>
  {{ adsense_head | safe }}
  {% if cookie_consent_i18n is defined and cookie_consent_i18n %}
  <script>window.COOKIE_CONSENT_I18N = {{ cookie_consent_i18n | tojson }};</script>
  {% endif %}
  {% if cookie_consent_script is defined and cookie_consent_script %}
  {{ cookie_consent_script | safe }}
  {% endif %}
</head>
<body>

<a href="#main-content" class="skip-link">Skip to content</a>

<header>
  <div class="header-inner">
    <a class="logo" href="/{{ lang }}/">
      <img src="/favicon.svg" alt="" class="logo-icon" width="32" height="32">
      Calc<span>To</span>Work
    </a>
    <button class="menu-toggle" id="menu-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="nav-wrapper">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <div class="nav-wrapper" id="nav-wrapper">
      <nav>
        <a href="/{{ lang }}/">{{ t.nav_home }}</a>
      </nav>
      <div class="lang-switcher" aria-label="Language">
        {% for alt_lang in all_langs %}
        <a href="/{{ alt_lang }}/{{ page_slug }}/"{% if alt_lang == lang %} class="active"{% endif %}>{{ alt_lang | upper }}</a>
        {% endfor %}
        <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">&#9790;</button>
      </div>
    </div>
  </div>
</header>
<script>
(function(){
  var btn=document.getElementById('menu-toggle'),nav=document.getElementById('nav-wrapper');
  if(!btn||!nav)return;
  btn.addEventListener('click',function(){
    var open=nav.classList.toggle('open');
    btn.setAttribute('aria-expanded',open);
    btn.innerHTML=open
      ? '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="4" y1="4" x2="20" y2="20"/><line x1="20" y1="4" x2="4" y2="20"/></svg>'
      : '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>';
  });
  document.addEventListener('click',function(e){
    if(!nav.contains(e.target)&&!btn.contains(e.target)&&nav.classList.contains('open')){
      nav.classList.remove('open');btn.setAttribute('aria-expanded','false');
      btn.innerHTML='<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>';
    }
  });
})();
</script>

<main class="container" id="main-content">
  <nav class="breadcrumb" aria-label="breadcrumb">
    <a href="/{{ lang }}/">{{ t.nav_home }}</a>
    <span class="breadcrumb-sep" aria-hidden="true">›</span>
    <span aria-current="page">{{ page_title }}</span>
  </nav>

  <div class="static-page">
    <h1>{{ page_title }}</h1>
    <div class="static-page-content">
      {{ page_body | safe }}
    </div>
    {% if author_line %}
    <p class="author-line">{{ author_line }}</p>
    {% endif %}
  </div>
</main>

<footer>
  <div class="footer-inner">
    <div>&copy; <span id="yr"></span> CalcToWork &mdash; {{ t.footer_rights }}</div>
    <div class="mt-1" style="font-size:.8rem;">{{ t.footer_disclaimer }}</div>
    <div class="footer-legal">
      <a href="/{{ lang }}/privacy/">{{ t.nav_privacy }}</a>
      <a href="/{{ lang }}/terms/">{{ t.nav_terms }}</a>
      <a href="/{{ lang }}/contact/">{{ t.nav_contact }}</a>
      <a href="/{{ lang }}/about/">{{ t.nav_about }}</a>
    </div>
    <div class="footer-links">
      {% for alt_lang in all_langs %}
      <a href="/{{ alt_lang }}/{{ page_slug }}/">{{ alt_lang | upper }}</a>
      {% endfor %}
    </div>
  </div>
</footer>

<script>document.getElementById('yr').textContent = new Date().getFullYear();</script>
<script src="/js/dark-mode.js"></script>
</body>
</html>
