<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ t.site_name }} – {{ t.site_tagline }}</title>
  <meta name="description" content="{{ t.site_description }}">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="https://obracalc.com/{{ lang }}/">

  {% for alt_lang in all_langs %}
  <link rel="alternate" hreflang="{{ alt_lang }}" href="https://obracalc.com/{{ alt_lang }}/">
  {% endfor %}
  <link rel="alternate" hreflang="x-default" href="https://obracalc.com/es/">

  <meta property="og:title" content="{{ t.site_name }} – {{ t.site_tagline }}">
  <meta property="og:description" content="{{ t.site_description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://obracalc.com/{{ lang }}/">
  <meta property="og:site_name" content="ObraCalc">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "ObraCalc",
    "url": "https://obracalc.com/",
    "description": {{ t.site_description | tojson }},
    "inLanguage": "{{ lang }}",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://obracalc.com/{{ lang }}/?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>

  <link rel="stylesheet" href="/css/styles.css">
  {{ adsense_head | safe }}
</head>
<body>

<header>
  <div class="header-inner">
    <a class="logo" href="/{{ lang }}/"><span>Obra</span>Calc</a>
    <nav>
      <a href="/{{ lang }}/">{{ t.nav_home }}</a>
    </nav>
    <div class="lang-switcher">
      {% for alt_lang in all_langs %}
      <a href="/{{ alt_lang }}/"{% if alt_lang == lang %} class="active"{% endif %}>{{ alt_lang | upper }}</a>
      {% endfor %}
    </div>
  </div>
</header>

<!-- Hero -->
<section class="hero">
  <h1><span>Obra</span>Calc</h1>
  <p>{{ t.site_description }}</p>
</section>

<div class="container">
  <div class="ad-slot ad-slot-banner">{{ adsense_banner | safe }}</div>
</div>

<main class="container">
  <div class="text-center mt-2">
    <div class="section-title">{{ t.nav_calculators }}</div>
    <div class="section-sub">100 {{ t.nav_calculators }}</div>
  </div>

  <div class="blocks-grid">
    {% for block_slug, block_calcs in blocks_by_slug.items() %}
    <div class="block-card">
      <div class="block-card-header">
        <div class="block-icon">{{ block_icons[block_slug] }}</div>
        <div class="block-title">{{ t.blocks[block_slug] }}</div>
      </div>
      <ul class="calc-list">
        {% for calc in block_calcs %}
        <li>
          <a href="/{{ lang }}/{{ calc.block_slug }}/{{ calc.slug }}/">
            {{ calcs_i18n[calc.id].name }}
          </a>
        </li>
        {% endfor %}
      </ul>
      <div class="mt-2">
        <a href="/{{ lang }}/{{ block_slug }}/" style="font-size:.82rem;color:var(--primary);text-decoration:none;">
          Ver todos →
        </a>
      </div>
    </div>
    {% endfor %}
  </div>

  <div class="ad-slot ad-slot-responsive mt-3">{{ adsense_responsive | safe }}</div>
</main>

<footer>
  <div class="footer-inner">
    <div>© <span id="yr"></span> ObraCalc — {{ t.footer_rights }}</div>
    <div class="mt-1" style="font-size:.8rem;">{{ t.footer_disclaimer }}</div>
    <div class="footer-links">
      {% for alt_lang in all_langs %}
      <a href="/{{ alt_lang }}/">{{ alt_lang | upper }}</a>
      {% endfor %}
    </div>
  </div>
</footer>

<script>document.getElementById('yr').textContent = new Date().getFullYear();</script>
</body>
</html>
