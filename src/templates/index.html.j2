<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {{ ga4_head | safe }}
  <title>{{ t.home_title | default('CalcToWork – Free Online Calculators') }}</title>
  <meta name="description" content="{{ t.site_description }}">
  <meta name="robots" content="index, follow">
  <meta name="theme-color" content="#f97316">
  <link rel="canonical" href="{{ site_base_url }}/{{ lang }}/">

  {% for alt_lang in all_langs %}
  <link rel="alternate" hreflang="{{ alt_lang }}" href="{{ site_base_url }}/{{ alt_lang }}/">
  {% endfor %}
  <link rel="alternate" hreflang="x-default" href="{{ site_base_url }}/en/">

  <meta property="og:title" content="CalcToWork – {{ t.site_tagline }}">
  <meta property="og:description" content="{{ t.site_description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site_base_url }}/{{ lang }}/">
  <meta property="og:site_name" content="CalcToWork">
  <meta property="og:image" content="{{ site_base_url }}/favicon.svg">
  <meta property="og:locale" content="{{ 'es_ES' if lang=='es' else 'en_US' if lang=='en' else 'fr_FR' if lang=='fr' else 'pt_BR' if lang=='pt' else 'de_DE' if lang=='de' else 'it_IT' }}">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="CalcToWork – {{ t.site_tagline }}">
  <meta name="twitter:description" content="{{ t.site_description }}">
  <meta name="twitter:image" content="{{ site_base_url }}/favicon.svg">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "CalcToWork",
    "url": "{{ site_base_url }}/",
    "description": {{ t.site_description | tojson }},
    "inLanguage": "{{ lang }}"
  }
  </script>

  <meta name="google-site-verification" content="IODnwsJUNWyjMxqiXR1jY6lM-4IR7r-n0rgZ6OGMdLg">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://pagead2.googlesyndication.com">
  <link rel="stylesheet" href="/css/styles.css">
  {{ adsense_head | safe }}
</head>
<body>

<a href="#main-content" class="skip-link">Skip to content</a>

<header>
  <div class="header-inner">
    <a class="logo" href="/{{ lang }}/">
      <img src="/favicon.svg" alt="" class="logo-icon" width="32" height="32">
      Calc<span>To</span>Work
    </a>
    <nav>
      <a href="/{{ lang }}/">{{ t.nav_home }}</a>
    </nav>
    <div class="lang-switcher" aria-label="Language">
      {% for alt_lang in all_langs %}
      <a href="/{{ alt_lang }}/"{% if alt_lang == lang %} class="active"{% endif %}>{{ alt_lang | upper }}</a>
      {% endfor %}
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">&#9790;</button>
    </div>
  </div>
</header>

<!-- Hero -->
<section class="hero">
  <h1>{{ t.home_h1 | default('Free Online Calculators') }}</h1>
  <p>{{ t.site_tagline }}</p>
</section>

<div class="container">
  <div class="ad-slot ad-slot-banner">{{ adsense_banner | safe }}</div>
</div>

<script>
window.CALC_INDEX = {{ calc_index_json | safe }};
</script>

<main class="container" id="main-content">
  <div class="text-center mt-2">
    <div class="section-title">{{ t.nav_calculators }}</div>
    <div class="section-sub">{{ calc_count | default(188) }} {{ t.nav_calculators }}</div>
  </div>

  <!-- Search box -->
  <div class="search-box-wrap">
    <label for="calc-search" class="sr-only">{{ t.search_placeholder | default('Search calculators') }}</label>
    <input
      type="search"
      id="calc-search"
      class="calc-search-input"
      placeholder="{{ t.search_placeholder | default('Search calculators…') }}"
      autocomplete="off"
      spellcheck="false"
      aria-label="{{ t.search_placeholder | default('Search calculators') }}"
    >
    <div id="search-no-results" class="search-no-results" style="display:none;">
      {{ t.search_no_results | default('No calculators found.') }}
    </div>
  </div>

  <div class="blocks-grid" id="blocks-grid">
    {% for block_slug, block_calcs in blocks_by_slug.items() %}
    <div class="block-card">
      <div class="block-card-header">
        <div class="block-icon">{{ block_icons[block_slug] }}</div>
        <div class="block-title">{{ t.blocks[block_slug] }}</div>
      </div>
      <ul class="calc-list">
        {% for calc in block_calcs %}
        <li>
          <a href="/{{ lang }}/{{ calc_url_by_id.get(calc.id, calc.block_slug + '/' + calc.slug) }}/">
            {{ calcs_i18n[calc.id].name }}
          </a>
        </li>
        {% endfor %}
      </ul>
      <div class="mt-2">
        <a href="/{{ lang }}/{{ block_slug }}/" style="font-size:.82rem;color:var(--primary);text-decoration:none;">
          {{ t.nav_calculators }} →
        </a>
      </div>
    </div>
    {% endfor %}
  </div>

  <div class="ad-slot ad-slot-responsive mt-3">{{ adsense_responsive | safe }}</div>

  {% if author_line %}
  <p class="author-line">{{ author_line }}</p>
  {% endif %}
</main>

<footer>
  <div class="footer-inner">
    <div>© <span id="yr"></span> CalcToWork — {{ t.footer_rights }}</div>
    <div class="mt-1" style="font-size:.8rem;">{{ t.footer_disclaimer }}</div>
    <div class="footer-legal">
      <a href="/{{ lang }}/privacy/">{{ t.nav_privacy }}</a>
      <a href="/{{ lang }}/terms/">{{ t.nav_terms }}</a>
      <a href="/{{ lang }}/contact/">{{ t.nav_contact }}</a>
      <a href="/{{ lang }}/about/">{{ t.nav_about }}</a>
    </div>
    <div class="footer-links">
      {% for alt_lang in all_langs %}
      <a href="/{{ alt_lang }}/">{{ alt_lang | upper }}</a>
      {% endfor %}
    </div>
  </div>
</footer>

<script>
document.getElementById('yr').textContent = new Date().getFullYear();

/* ── Calculator search ── */
(function () {
  var searchInput = document.getElementById('calc-search');
  var noResults   = document.getElementById('search-no-results');
  var blocksGrid  = document.getElementById('blocks-grid');
  if (!searchInput || !blocksGrid) return;

  function filterCalcs() {
    var q = searchInput.value.trim().toLowerCase();
    var blockCards = blocksGrid.querySelectorAll('.block-card');
    var totalVisible = 0;

    blockCards.forEach(function (card) {
      var links = card.querySelectorAll('.calc-list a');
      var cardVisible = 0;
      links.forEach(function (a) {
        var text = a.textContent.trim().toLowerCase();
        var show = !q || text.indexOf(q) !== -1;
        a.parentElement.style.display = show ? '' : 'none';
        if (show) cardVisible++;
      });
      card.style.display = cardVisible > 0 ? '' : 'none';
      totalVisible += cardVisible;
    });

    if (noResults) noResults.style.display = (q && totalVisible === 0) ? '' : 'none';
  }

  searchInput.addEventListener('input', filterCalcs);
  searchInput.addEventListener('search', filterCalcs);
})();
</script>
<script src="/js/dark-mode.js"></script>
</body>
</html>
