<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {{ ga4_head | safe }}
  <title>{{ block_name }} – CalcToWork</title>
  <meta name="description" content="{{ block_description }}">
  <meta name="robots" content="index, follow">
  <meta name="theme-color" content="#f97316">
  <link rel="canonical" href="{{ site_base_url }}/{{ lang }}/{{ block_slug }}/">

  {% for alt_lang in all_langs %}
  <link rel="alternate" hreflang="{{ alt_lang }}" href="{{ site_base_url }}/{{ alt_lang }}/{{ block_slug }}/">
  {% endfor %}
  <link rel="alternate" hreflang="x-default" href="{{ site_base_url }}/en/{{ block_slug }}/">

  <meta property="og:title" content="{{ block_name }} – CalcToWork">
  <meta property="og:description" content="{{ block_description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site_base_url }}/{{ lang }}/{{ block_slug }}/">
  <meta property="og:site_name" content="CalcToWork">
  <meta property="og:image" content="{{ site_base_url }}/favicon.svg">
  <meta property="og:locale" content="{{ 'es_ES' if lang=='es' else 'en_US' if lang=='en' else 'fr_FR' if lang=='fr' else 'pt_BR' if lang=='pt' else 'de_DE' if lang=='de' else 'it_IT' }}">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{{ block_name }} – CalcToWork">
  <meta name="twitter:description" content="{{ block_description }}">
  <meta name="twitter:image" content="{{ site_base_url }}/favicon.svg">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": {{ block_name | tojson }},
    "url": "{{ site_base_url }}/{{ lang }}/{{ block_slug }}/",
    "inLanguage": "{{ lang }}",
    "isPartOf": {
      "@type": "WebSite",
      "name": "CalcToWork",
      "url": "{{ site_base_url }}/"
    }
  }
  </script>

  <meta name="google-site-verification" content="IODnwsJUNWyjMxqiXR1jY6lM-4IR7r-n0rgZ6OGMdLg">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/x-icon" sizes="32x32" href="/favicon.ico">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="preconnect" href="https://pagead2.googlesyndication.com">
  <link rel="preconnect" href="https://www.googletagmanager.com">
  <link rel="stylesheet" href="/css/styles.css">
  <script>if(localStorage.getItem('ctw-theme')==='dark')document.documentElement.setAttribute('data-theme','dark');</script>
  {{ adsense_head | safe }}
</head>
<body>

<a href="#main-content" class="skip-link">Skip to content</a>

<header>
  <div class="header-inner">
    <a class="logo" href="/{{ lang }}/">
      <img src="/favicon.svg" alt="" class="logo-icon" width="32" height="32">
      Calc<span>To</span>Work
    </a>
    <nav>
      <a href="/{{ lang }}/">{{ t.nav_home }}</a>
      <a href="/{{ lang }}/{{ block_slug }}/">{{ block_name }}</a>
    </nav>
    <div class="lang-switcher" aria-label="Language">
      {% for alt_lang in all_langs %}
      <a href="/{{ alt_lang }}/{{ block_slug }}/"{% if alt_lang == lang %} class="active"{% endif %}>{{ alt_lang | upper }}</a>
      {% endfor %}
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">&#9790;</button>
    </div>
  </div>
</header>

<section class="block-hero">
  <div class="container">
    <nav class="breadcrumb" aria-label="breadcrumb" style="color:#64748b;margin-bottom:.75rem;">
      <a href="/{{ lang }}/" style="color:var(--primary);">{{ t.nav_home }}</a>
      <span class="breadcrumb-sep" aria-hidden="true">›</span>
      <span aria-current="page">{{ block_name }}</span>
    </nav>
    <h1><span>{{ block_name }}</span></h1>
    <p>{{ block_description }}</p>
  </div>
</section>

<div class="container">
  <div class="ad-slot ad-slot-banner">{{ adsense_banner | safe }}</div>
</div>

<main class="container" id="main-content">
  <div class="calcs-grid">
    {% for calc in block_calcs %}
    <a class="calc-thumb" href="/{{ lang }}/{{ calc_url_by_id.get(calc.id, calc.block_slug + '/' + calc.slug) }}/">
      <div class="calc-thumb-num">#{{ calc.id }}</div>
      <h3>{{ calcs_i18n[calc.id].name }}</h3>
      <p>{{ calcs_i18n[calc.id].description }}</p>
    </a>
    {% endfor %}
  </div>

  <div class="ad-slot ad-slot-responsive mt-3">{{ adsense_responsive | safe }}</div>
</main>

<footer>
  <div class="footer-inner">
    <div>© <span id="yr"></span> CalcToWork — {{ t.footer_rights }}</div>
    <div class="mt-1" style="font-size:.8rem;">{{ t.footer_disclaimer }}</div>
    <div class="footer-legal">
      <a href="/{{ lang }}/privacy/">{{ t.nav_privacy }}</a>
      <a href="/{{ lang }}/terms/">{{ t.nav_terms }}</a>
      <a href="/{{ lang }}/contact/">{{ t.nav_contact }}</a>
      <a href="/{{ lang }}/about/">{{ t.nav_about }}</a>
    </div>
    <div class="footer-links">
      {% for alt_lang in all_langs %}
      <a href="/{{ alt_lang }}/{{ block_slug }}/">{{ alt_lang | upper }}</a>
      {% endfor %}
    </div>
  </div>
</footer>

<script>document.getElementById('yr').textContent = new Date().getFullYear();</script>
<script src="/js/dark-mode.js"></script>
</body>
</html>
