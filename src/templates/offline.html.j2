<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Offline | CalcToWork</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <header>
    <div class="container nav-bar">
      <a href="/" class="brand">CalcToWork</a>
    </div>
  </header>
  <main class="container" style="text-align:center;padding:4rem 1rem;">
    <h1 style="font-size:2rem;margin-bottom:1rem;">You're offline</h1>
    <p style="color:var(--text-muted);margin-bottom:2rem;">Some calculators may still work if you've visited them before.</p>
    <p><a href="/" class="btn btn-primary">Try going home</a></p>
  </main>
  <footer>
    <div class="container footer-inner">
      <p>&copy; <span id="yr"></span> CalcToWork</p>
    </div>
  </footer>
  <script>document.getElementById('yr').textContent = new Date().getFullYear();</script>
</body>
</html>
