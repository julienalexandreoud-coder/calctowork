<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  {{ ga4_head | safe }}
  <title>{% if seo_title_override is defined and seo_title_override %}{{ seo_title_override }}{% else %}{{ calc_i18n.seo_title }}{% endif %} | CalcToWork</title>
  <meta name="description" content="{% if seo_desc_override is defined and seo_desc_override %}{{ seo_desc_override }}{% else %}{{ calc_i18n.seo_description }}{% endif %}">
  <meta name="robots" content="{% if is_parametric_variant %}noindex, follow{% else %}index, follow{% endif %}">
  <meta name="theme-color" content="#f97316">
  <link rel="preload" as="style" href="/css/styles.css">
  <link rel="preload" as="script" href="/js/calculator.js">
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>

  {# ── Resolve URL paths (supports both flat and block/slug structures) ── #}
  {% set _base = site_base_url | default("https://calcto.work") %}
  {% set _path = calc_url_path | default(calc.block_slug + "/" + calc.slug) %}
  {% set _alt  = calc_alt_slugs | default({}) %}

  <link rel="canonical" href="{{ _base }}/{{ lang }}/{{ _path }}/">

  {% for alt_lang in all_langs %}
  {% set _ap = _alt[alt_lang] if (alt_lang in _alt) else _path %}
  <link rel="alternate" hreflang="{{ alt_lang }}" href="{{ _base }}/{{ alt_lang }}/{{ _ap }}/">
  {% endfor %}
  <link rel="alternate" hreflang="x-default" href="{{ _base }}/en/{{ _alt['en'] if 'en' in _alt else _path }}/">

  <meta property="og:title" content="{{ calc_i18n.seo_title }}">
  <meta property="og:description" content="{{ calc_i18n.seo_description }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ _base }}/{{ lang }}/{{ _path }}/">
  <meta property="og:site_name" content="CalcToWork">
  <meta property="og:image" content="{{ _base }}/og/{{ calc.block_slug }}.png">
  <meta property="og:locale" content="{{ 'es_ES' if lang=='es' else 'en_US' if lang=='en' else 'fr_FR' if lang=='fr' else 'pt_BR' if lang=='pt' else 'de_DE' if lang=='de' else 'it_IT' }}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ calc_i18n.seo_title }}">
  <meta name="twitter:description" content="{{ calc_i18n.seo_description }}">
  <meta name="twitter:image" content="{{ _base }}/og/{{ calc.block_slug }}.png">

  <!-- Schema: SoftwareApplication -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": {{ calc_i18n.name | tojson }},
    "description": {{ calc_i18n.seo_description | tojson }},
    "url": "{{ _base }}/{{ lang }}/{{ _path }}/",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "inLanguage": "{{ lang }}",
    "isPartOf": { "@type": "WebSite", "name": "CalcToWork", "url": "{{ _base }}/" }
  }
  </script>

  {% if long_content %}
  <!-- Schema: Article -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": {{ calc_i18n.name | tojson }},
    "description": {{ calc_i18n.seo_description | tojson }},
    "author": {
      "@type": "Organization",
      "name": "CalcToWork Editorial Team",
      "url": "{{ _base }}/"
    },
    "publisher": { "@type": "Organization", "name": "CalcToWork", "url": "{{ _base }}/" },
    "url": "{{ _base }}/{{ lang }}/{{ _path }}/",
    "mainEntityOfPage": "{{ _base }}/{{ lang }}/{{ _path }}/",
    "inLanguage": "{{ lang }}",
    "datePublished": "{{ date_published | default('2025-01-01') }}",
    "dateModified": "{{ date_modified | default(BUILD_DATE) }}"
  }
  </script>
  {% endif %}

  <!-- Schema: BreadcrumbList -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {"@type":"ListItem","position":1,"name":"CalcToWork","item":"{{ _base }}/{{ lang }}/"},
      {"@type":"ListItem","position":2,"name":{{ block_name | tojson }},"item":"{{ _base }}/{{ lang }}/{{ calc.block_slug }}/"},
      {"@type":"ListItem","position":3,"name":{{ calc_i18n.name | tojson }},"item":"{{ _base }}/{{ lang }}/{{ _path }}/"}
    ]
  }
  </script>

  {% if faq %}
  <!-- Schema: FAQPage -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {% for item in faq %}
      {
        "@type": "Question",
        "name": {{ item.q | tojson }},
        "acceptedAnswer": { "@type": "Answer", "text": {{ item.a | tojson }} }
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
  </script>
  {% endif %}

  {% if how_to_steps %}
  <!-- Schema: HowTo -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": {{ calc_i18n.name | tojson }},
    "description": {{ calc_i18n.seo_description | tojson }},
    "step": [
      {% for step in how_to_steps %}
      {
        "@type": "HowToStep",
        "position": {{ loop.index }},
        "text": {{ step | tojson }}
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
  </script>
  {% endif %}

  <link rel="manifest" href="/manifest.json">
  <meta name="google-site-verification" content="IODnwsJUNWyjMxqiXR1jY6lM-4IR7r-n0rgZ6OGMdLg">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/x-icon" sizes="32x32" href="/favicon.ico">
  <link rel="apple-touch-icon" sizes="192x192" href="/img/pwa/icon-192.png">
  <link rel="preconnect" href="https://pagead2.googlesyndication.com">
  <link rel="preconnect" href="https://www.googletagmanager.com">
  <link rel="stylesheet" href="/css/styles.css">
  {% if formula_explained or long_content %}
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" integrity="sha384-n8MVd4RsNIU0tAv4ct0nTaAbDJwPJzDEaqSD1odI+WdtXRGWt2kTvGFasHpSy3SV" crossorigin="anonymous">
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js" integrity="sha384-XjKyOOlGwcjNTAIQHIpgOno0Hl1YrqzHgFeFEpC71bBHsl7UO2/9ueHz3pwpB9z4" crossorigin="anonymous"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js" integrity="sha384-+VBxd3r6XgURycqt+117yCQKLkYWuOgR8BHans9j6A4zSfL5N6p3G9v9lL/6j7G0" crossorigin="anonymous"
    onload="renderMathInElement(document.body, {delimiters: [{left: '$$', right: '$$', display: true}, {left: '$', right: '$', display: false}]});"></script>
  {% endif %}
  <script>if(localStorage.getItem('ctw-theme')==='dark')document.documentElement.setAttribute('data-theme','dark');</script>
  {{ adsense_head | safe }}
  {% if cookie_consent_i18n is defined and cookie_consent_i18n %}
  <script>window.COOKIE_CONSENT_I18N = {{ cookie_consent_i18n | tojson }};</script>
  {% endif %}
  {% if cookie_consent_script is defined and cookie_consent_script %}
  {{ cookie_consent_script | safe }}
  {% endif %}
</head>
<body>

<a href="#main-content" class="skip-link">Skip to content</a>

<!-- Header -->
<header>
  <div class="header-inner">
    <a class="logo" href="/{{ lang }}/">
      <img src="/favicon.svg" alt="" class="logo-icon" width="32" height="32">
      Calc<span>To</span>Work
    </a>
    <button class="menu-toggle" id="menu-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="nav-wrapper">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <div class="nav-wrapper" id="nav-wrapper">
      <nav>
        <a href="/{{ lang }}/">{{ t.nav_home }}</a>
        <a href="/{{ lang }}/{{ calc.block_slug }}/">{{ block_name }}</a>
      </nav>
      <div class="lang-switcher" aria-label="Language">
        {% for alt_lang in all_langs %}
        {% set _ap2 = _alt[alt_lang] if (alt_lang in _alt) else _path %}
        <a href="/{{ alt_lang }}/{{ _ap2 }}/"{% if alt_lang == lang %} class="active"{% endif %}>{{ alt_lang | upper }}</a>
        {% endfor %}
        <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">&#9790;</button>
      </div>
    </div>
  </div>
</header>
<script>
(function(){
  var btn=document.getElementById('menu-toggle'),nav=document.getElementById('nav-wrapper');
  if(!btn||!nav)return;
  btn.addEventListener('click',function(){
    var open=nav.classList.toggle('open');
    btn.setAttribute('aria-expanded',open);
    btn.innerHTML=open
      ? '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="4" y1="4" x2="20" y2="20"/><line x1="20" y1="4" x2="4" y2="20"/></svg>'
      : '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>';
  });
  document.addEventListener('click',function(e){
    if(!nav.contains(e.target)&&!btn.contains(e.target)&&nav.classList.contains('open')){
      nav.classList.remove('open');
      btn.setAttribute('aria-expanded','false');
      btn.innerHTML='<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>';
    }
  });
})();
</script>

<!-- Ad banner top -->
<div class="container">
  <div class="ad-slot ad-slot-banner">{{ adsense_banner | safe }}</div>
</div>

<main class="container" id="main-content">

  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="breadcrumb">
    <a href="/{{ lang }}/">{{ t.nav_home }}</a>
    <span class="breadcrumb-sep" aria-hidden="true">›</span>
    <a href="/{{ lang }}/{{ calc.block_slug }}/">{{ block_name }}</a>
    <span class="breadcrumb-sep" aria-hidden="true">›</span>
    <span aria-current="page">{{ calc_i18n.name }}</span>
  </nav>

  <!-- H1 + description -->
  <div class="calc-header">
    <h1>{% if seo_title_override is defined and seo_title_override %}{{ seo_title_override }}{% else %}{{ calc_i18n.name }}{% endif %}</h1>
    <p>{{ calc_i18n.description }}</p>
    <p class="last-updated">{{ t.last_updated | default('Last updated') }}: {{ date_modified | default(BUILD_DATE) }}</p>
  </div>

  <!-- Favorite button -->
  <button id="fav-btn" class="fav-btn" data-calc-id="{{ calc.id }}" data-calc-name="{{ calc_i18n.name }}" title="Save to favorites">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
  </button>
  <script src="/js/favorites.js" defer></script>

  <!-- Intro paragraph (SEO) -->
  <div class="calc-intro">{{ intro_text | safe }}</div>

  <div class="sticky-sentinel" aria-hidden="true"></div>

  {% if toc_items %}
  <div class="content-with-toc">
    <aside class="toc-sidebar">
      <div class="toc-title">{{ toc_title }}</div>
      <nav>
        {% for item in toc_items %}
        <a class="toc-link" href="#{{ item.id }}">{{ item.text }}</a>
        {% endfor %}
      </nav>
    </aside>
    <div class="content-main">
  {% endif %}

  <!-- Calculator grid -->
  <div class="calc-layout">

    <!-- Inputs -->
    <div class="card">
      <div class="card-title">{{ t.label_inputs }}</div>
      <form id="calc-form" novalidate>

        {% if input_groups %}
          {# ── Grouped inputs (CalcToWork mode) ── #}
          {% set show_headings = (input_groups|length > 1) or (input_groups|length == 1 and input_groups[0].id != 'other') %}
          {% for group in input_groups %}
          {% if group.fields %}
          <fieldset class="input-group-fieldset">
          {% if show_headings %}
          <legend class="input-group-heading">
            <span aria-hidden="true">{{ group.icon }}</span>
            {{ group.label }}
          </legend>
          {% endif %}
          {% for field in group.fields %}
          <div class="form-group">
            <label for="input-{{ field.key }}">{{ field.label }}</label>
            {% if field.type == 'select' %}
            <select class="form-select" id="input-{{ field.key }}" name="{{ field.key }}" required>
              {% for opt in field.options %}
              <option value="{{ opt.value }}" {% if opt.selected %}selected{% endif %}>{{ opt.label }}</option>
              {% endfor %}
            </select>
            {% else %}
            <div class="input-with-unit">
              <input
                type="number"
                id="input-{{ field.key }}"
                name="{{ field.key }}"
                inputmode="decimal"
                {% if field.min is not none %}min="{{ field.min }}"{% endif %}
                {% if field.max is not none %}max="{{ field.max }}"{% endif %}
                {% if field.step is not none %}step="{{ field.step }}"{% else %}step="any"{% endif %}
                placeholder="{{ input_placeholders.get(field.key, '') }}"
                autocomplete="off"
                required
              >
              {% if field.unit_options %}
              <select class="unit-select" data-input="{{ field.key }}" data-category="{{ field.unit_category }}">
                {% for u in field.unit_options %}
                <option value="{{ u }}" {% if u == field.unit_default %}selected{% endif %}>{{ t.unit_labels.get(u, u) if t.unit_labels is defined else u }}</option>
                {% endfor %}
              </select>
              {% endif %}
            </div>
            {% endif %}
          </div>
          {% endfor %}
          {% endif %}
          </fieldset>
          {% endfor %}
        {% else %}
          {# ── Flat inputs (legacy mode) ── #}
          {% for input_key, input_label in calc_i18n.inputs.items() %}
          {% set meta = input_meta.get(input_key, {}) %}
          {% set unit_opts = meta.get('unit_options', []) %}
          <div class="form-group">
            <label for="input-{{ input_key }}">{{ input_label }}</label>
            <div class="input-with-unit">
              <input
                type="number"
                id="input-{{ input_key }}"
                name="{{ input_key }}"
                inputmode="decimal"
                {% if meta.get('min') is not none %}min="{{ meta.min }}"{% endif %}
                {% if meta.get('max') is not none %}max="{{ meta.max }}"{% endif %}
                {% if meta.get('step') is not none %}step="{{ meta.step }}"{% else %}step="any"{% endif %}
                placeholder="{{ input_placeholders.get(input_key, '') }}"
                autocomplete="off"
                required
              >
              {% if unit_opts %}
              <select class="unit-select" data-input="{{ input_key }}" data-category="{{ meta.get('unit_category', '') }}">
                {% for u in unit_opts %}
                <option value="{{ u }}" {% if u == meta.get('unit', '') %}selected{% endif %}>{{ t.unit_labels.get(u, u) if t.unit_labels is defined else u }}</option>
                {% endfor %}
              </select>
              {% endif %}
            </div>
          </div>
          {% endfor %}
        {% endif %}

        <!-- Price estimation (optional, construction calculators) -->
        {% if price_inputs is defined and price_inputs %}
        <details class="price-inputs-wrap">
          <summary class="price-inputs-toggle">&#128176; {{ t.price_section_label | default('Add prices for cost estimate (optional)') }}</summary>
          <div class="price-inputs-body">
            {% for pi in price_inputs %}
            <div class="form-group">
              <label for="price-{{ pi.id }}">{{ pi.label }}</label>
              <div class="input-with-unit">
                <input type="number" id="price-{{ pi.id }}" name="price-{{ pi.id }}" inputmode="decimal" step="any" min="0" placeholder="0.00" autocomplete="off" data-price-for="{{ pi.ties_to }}">
                <span class="unit-label">{{ pi.currency | default('$') }}/{{ pi.unit_label | default('unit') }}</span>
              </div>
            </div>
            {% endfor %}
          </div>
        </details>
        {% endif %}

        <!-- Wastage input -->
        {% if show_wastage is not defined or show_wastage %}
        <div class="form-group wastage-group">
          <label for="input-desperdicio_merma">{{ wastage_label }}</label>
          <input
            type="number"
            id="input-desperdicio_merma"
            name="desperdicio_merma"
            inputmode="decimal"
            step="1"
            min="0"
            max="50"
            value="{{ wastage_default | default(10) }}"
            placeholder="{{ wastage_placeholder }}"
            autocomplete="off"
          >
        </div>
        {% endif %}

        <div class="btn-row">
          <button type="submit" class="btn btn-primary">{{ t.btn_calculate }}</button>
          <button type="button" class="btn btn-secondary" id="btn-reset">{{ t.btn_reset }}</button>
        </div>
      </form>
    </div>

    <!-- Results -->
    <div class="card results-panel">
      <div class="card-title">{{ t.label_results }}</div>
      <div id="result-gauge" style="display:none;"></div>
      <div id="calc-results" aria-live="polite">
        <div class="result-placeholder">{{ t.result_placeholder | default('Enter values and press Calculate') }}</div>
      </div>
      <div id="calc-history" class="calc-history" style="display:none;"></div>
      <div class="results-actions">
        <button class="btn btn-secondary copy-btn" id="btn-copy" style="display:none;">
          {{ t.btn_copy }}
        </button>
        <button class="btn btn-secondary share-btn" id="btn-share" style="display:none;">
          {{ btn_share_label | default('🔗 Share') }}
        </button>
        <button class="btn btn-secondary embed-btn" id="btn-embed" style="display:none;" title="{{ t.btn_embed | default('Embed this calculator') }}">
          &lt;/&gt; {{ t.btn_embed | default('Embed') }}
        </button>
        <button class="btn btn-secondary" id="btn-pdf" style="display:none;" title="{{ t.btn_pdf | default('Download PDF') }}">
          &#8595; PDF
        </button>
        <button class="btn btn-secondary" id="btn-add-project" style="display:none;" title="{{ t.btn_add_project | default('Add to Project') }}">
          + {{ t.btn_add_project | default('Project') }}
        </button>
      </div>
      <div class="social-share" id="social-share" style="display:none;">
        <a class="social-btn whatsapp" id="btn-whatsapp" target="_blank" rel="noopener" aria-label="Share on WhatsApp" title="WhatsApp">&#160;</a>
        <a class="social-btn twitter" id="btn-twitter" target="_blank" rel="noopener" aria-label="Share on X" title="X / Twitter">&#160;</a>
        <a class="social-btn facebook" id="btn-facebook" target="_blank" rel="noopener" aria-label="Share on Facebook" title="Facebook">&#160;</a>
      </div>
      <!-- Sensitivity chart -->
      <div class="sensitivity-section" id="sensitivity-section" style="display:none;">
        <button class="sensitivity-toggle" id="sensitivity-toggle" type="button">
          📈 {{ t.sensitivity_toggle | default('Show how result changes') }}
        </button>
        <div class="sensitivity-chart-wrap" id="sensitivity-chart-wrap" style="display:none;">
          <canvas id="sensitivity-chart" width="600" height="280" tabindex="0" aria-label="Sensitivity chart. Use arrow keys to navigate points. Press Enter to apply."></canvas>
          <span id="sensitivity-live" class="sr-only" aria-live="polite" aria-atomic="true"></span>
        </div>
      </div>

      <div class="feedback-wrap">
        <span class="feedback-label">{{ feedback_label | default('Was this helpful?') }}</span>
        <button class="feedback-btn" data-val="yes" aria-label="Yes">&#128077;</button>
        <button class="feedback-btn" data-val="no" aria-label="No">&#128078;</button>
      </div>

      <!-- Email capture (PDF report) - moved inside results -->
      {% if email_capture_enabled is not defined or email_capture_enabled %}
      <div class="email-capture-box" id="email-capture-box" data-webhook="{{ email_webhook_url | default('') }}">
        <div class="email-capture-title">&#128196; {{ t.email_title | default('Save your calculation as PDF') }}</div>
        <p class="email-capture-desc">{{ t.email_desc | default('Enter your email and download a PDF report with your results.') }}</p>
        <form id="email-capture-form" class="email-capture-form">
          <input type="email" name="email" maxlength="120" placeholder="{{ t.email_placeholder | default('your@email.com') }}" required>
          <label class="email-consent-label">
            <input type="checkbox" id="email-consent" required>
            {{ t.email_consent | default('I agree to receive product updates by email.') }}
          </label>
          <button type="submit" class="btn btn-primary">{{ t.email_btn | default('Download PDF') }}</button>
        </form>
      </div>
      {% endif %}
    </div>

  </div><!-- /.calc-layout -->

  <!-- Comparison table (preset sizes) -->
  {% if comparison_table is defined and comparison_table %}
  <div class="comparison-table-wrap" tabindex="0" role="region" aria-label="{{ t.comparison_region_label | default('Comparison presets') }}">
    <div class="comparison-table-title">{{ t.comparison_table_title | default('Common Sizes — Click to Fill') }}</div>
    <table class="comparison-table" id="comparison-table">
      <thead>
        <tr>
          {% for col in comparison_table.headers %}
          <th>{{ col }}</th>
          {% endfor %}
        </tr>
      </thead>
      <tbody>
        {% for row in comparison_table.rows %}
        <tr data-prefill="{{ row.inputs | tojson | e }}">
          {% for val in row.display %}
          <td{% if loop.first and comparison_table.headers[0] == '' %} class="preset-label-cell"{% endif %}>{{ val }}</td>
          {% endfor %}
        </tr>
        {% endfor %}
      </tbody>
    </table>
    </div>
  </div>
  {% endif %}

  <!-- Ad responsive -->
  <div class="ad-slot ad-slot-responsive">{{ adsense_responsive | safe }}</div>

  <!-- Affiliate CTA (for calculators with affiliate offers) -->
  {% if affiliate_config is defined and affiliate_config %}
  <div class="affiliate-box">
    <div class="affiliate-inner">
      <div class="affiliate-text">{{ affiliate_config.text[lang] if lang in affiliate_config.text else affiliate_config.text['en'] }}</div>
      <a class="affiliate-cta" href="{{ affiliate_config.url }}" target="_blank" rel="sponsored noopener" data-affiliate="{{ affiliate_config.program }}">{{ affiliate_config.cta[lang] if lang in affiliate_config.cta else affiliate_config.cta['en'] }}</a>
    </div>
    <div class="affiliate-disclosure">Ad</div>
  </div>
  {% endif %}

  <!-- How to Use (suppressed when long-form article already covers steps) -->
  {% if how_to_steps and not has_long_content %}
  <div class="howto-section">
    <div class="howto-title">{{ howto_title }}</div>
    <ol class="howto-steps">
      {% for step in how_to_steps %}
      <li>{{ step }}</li>
      {% endfor %}
    </ol>
  </div>
  {% endif %}

  <!-- Formula explained (suppressed when long-form article already explains it) -->
  {% if formula_explained and not has_long_content %}
  <details class="formula-details">
    <summary class="formula-summary">{{ formula_title }}</summary>
    <div class="formula-body">{{ formula_explained }}</div>
  </details>
  {% endif %}

  <!-- Trust / E-E-A-T badge -->
  {% if trust_standard is defined and trust_standard %}
  <aside class="trust-badge">
    <span>&#128218;</span>
    <span>{{ t.trust_calculated_per | default('Calculated using') }} <strong>{{ trust_standard }}</strong>{% if trust_note %} &mdash; {{ trust_note }}{% endif %}</span>
  </aside>
  {% endif %}

  <!-- Diagram -->
  {% if calc_diagram is defined and calc_diagram %}
  <img src="/img/diagrams/{{ calc_diagram }}.svg" class="calc-diagram" alt="{{ calc_i18n.name }} diagram" width="320" height="200" loading="lazy">
  {% endif %}

  <!-- Related calculators -->
  {% if related_calcs %}
  <div class="related-section">
    <div class="related-title">{{ t.label_related }}</div>
    <div class="related-grid">
      {% for rel in related_calcs %}
      <a class="related-card" href="/{{ lang }}/{{ rel.url_path | default(rel.block_slug + '/' + rel.slug) }}/">{{ rel.name }}</a>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  <!-- Popular combinations (on base calculator pages with parametric variants) -->
  {% if popular_combos is defined and popular_combos %}
  <div class="popular-section">
    <div class="popular-title">{{ popular_combos_title }}</div>
    <div class="popular-grid">
      {% for combo in popular_combos %}
      <a class="popular-card" href="/{{ lang }}/{{ combo.path }}/">{{ combo.label }}</a>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  <!-- Long-form article content -->
  {% if long_content %}
  <div class="long-content-wrap">{{ long_content | safe }}</div>
  {% if adsense_inarticle is defined and adsense_inarticle %}
  <div class="ad-slot ad-slot-inarticle">{{ adsense_inarticle | safe }}</div>
  {% endif %}
  {% endif %}

  {% if author_line %}
  <p class="author-line">{{ author_line }}</p>
  {% endif %}

  {% if toc_items %}
    </div><!-- /.content-main -->
  </div><!-- /.content-with-toc -->
  {% endif %}

  <!-- FAQ (suppressed when long-form article already contains its own FAQ section) -->
  {% if faq and not has_long_content %}
  <section class="faq-section">
    <h2 class="faq-title">{{ faq_title }}</h2>
    {% for item in faq %}
    <div class="faq-item">
      <button class="faq-q" type="button" aria-expanded="false">
        {{ item.q }}
        <span class="faq-icon" aria-hidden="true">+</span>
      </button>
      <div class="faq-a" role="region">{{ item.a }}</div>
    </div>
    {% endfor %}
  </section>
  {% endif %}

  <div class="print-footer">calcto.work — {{ t.calculated_on | default('Calculated on') }} {{ BUILD_DATE }}</div>
</main>

<!-- Footer -->
<footer>
  <div class="footer-inner">
    <div>© <span id="yr"></span> CalcToWork — {{ t.footer_rights }}</div>
    <div class="mt-1" style="font-size:.8rem;">{{ t.footer_disclaimer }}</div>
    <div class="footer-legal">
      <a href="/{{ lang }}/privacy/">{{ t.nav_privacy }}</a>
      <a href="/{{ lang }}/terms/">{{ t.nav_terms }}</a>
      <a href="/{{ lang }}/contact/">{{ t.nav_contact }}</a>
      <a href="/{{ lang }}/about/">{{ t.nav_about }}</a>
    </div>
    <div class="footer-links">
      {% for alt_lang in all_langs %}
      {% set _ap3 = _alt[alt_lang] if (alt_lang in _alt) else _path %}
      <a href="/{{ alt_lang }}/{{ _ap3 }}/">{{ alt_lang | upper }}</a>
      {% endfor %}
    </div>
  </div>
</footer>

<!-- Project Tally floating panel -->
<div id="project-tally" class="project-tally" style="display:none;">
  <div class="project-tally-header">
    <span>&#128196; <strong id="project-tally-title">{{ t.project_tally_title | default('My Project') }}</strong></span>
    <button class="project-tally-close" id="btn-tally-close" aria-label="Close">&#10005;</button>
  </div>
  <div id="project-tally-items" class="project-tally-items"></div>
  <div class="project-tally-footer">
    <button class="btn btn-secondary btn-sm" id="btn-tally-pdf">&#8595; {{ t.btn_export_pdf | default('Export PDF') }}</button>
    <button class="btn btn-secondary btn-sm" id="btn-tally-clear">{{ t.btn_clear_all | default('Clear All') }}</button>
  </div>
</div>
<button id="btn-project-fab" class="project-fab" style="display:none;" title="{{ t.project_tally_title | default('My Project') }}">
  &#128196; <span id="project-fab-count" class="project-fab-count">0</span>
</button>

<script>
window.CALC_LANG = '{{ lang }}';
window.CALC_CONFIG = {
  formula: {{ calc.formula | tojson }},
  outputs: {{ calc_i18n.outputs | tojson }},
  showWastage: {{ 'true' if (show_wastage is not defined or show_wastage) else 'false' }},
  slug: "{{ calc_url_path | default(calc.block_slug + '/' + calc.slug) }}",
  calcId: "{{ calc.id }}",
  example_inputs: {{ calc.example_inputs | tojson }},
  {% if gauge_config %}
  gauge: {{ gauge_config | tojson }},
  {% endif %}
  {% if calc.buying_units %}
  buying_units: {{ calc.buying_units | tojson }},
  {% endif %}
  i18n: {
    seo_title: {{ calc_i18n.seo_title | tojson }},
    calc_name: {{ calc_i18n.name | tojson }},
    error_invalid: {{ t.error_invalid | tojson }},
    label_results: {{ t.label_results | tojson }},
    btn_copy: {{ t.btn_copy | tojson }},
    net_label: {{ net_label | tojson }},
    total_label: {{ total_label | tojson }},
    copied: {{ copied_label | tojson }},
    link_copied: {{ link_copied_label | tojson }},
    result_placeholder: {{ t.result_placeholder | default('Enter values and press Calculate') | tojson }},
    feedback_thanks: {{ feedback_thanks | tojson }},
    btn_pdf: {{ t.btn_pdf | default('Download PDF') | tojson }},
    cost_estimate_label: {{ t.cost_estimate_label | default('Estimated Cost') | tojson }},
    buying_unit_prefix: {{ t.buying_unit_prefix | default('→') | tojson }},
    project_tally_title: {{ t.project_tally_title | default('My Project') | tojson }},
    btn_add_project: {{ t.btn_add_project | default('Add to Project') | tojson }},
    btn_export_pdf: {{ t.btn_export_pdf | default('Export PDF') | tojson }},
    btn_clear_all: {{ t.btn_clear_all | default('Clear All') | tojson }},
    tally_empty: {{ t.tally_empty | default('No items yet. Calculate something and click "+ Project".') | tojson }},
    sensitivity_toggle: {{ t.sensitivity_toggle | default('Show how {output} changes with {input}') | tojson }},
    btn_embed: {{ t.btn_embed | default('Embed') | tojson }},
    embed_title: {{ t.embed_title | default('Embed this calculator') | tojson }},
    embed_desc: {{ t.embed_desc | default('Copy the code below to embed this calculator on your website:') | tojson }},
    btn_copy_embed: {{ t.btn_copy_embed | default('Copy embed code') | tojson }}
  }
};
</script>
{% if prefill_json is defined and prefill_json %}
<script>window.CALC_PREFILL = {{ prefill_json | safe }};</script>
{% endif %}
