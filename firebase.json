{
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "/sitemap.xml", "function": "sitemap" },
      { "source": "/:lang/:slug/", "function": "calcPage" }
    ],
    "redirects": [
      {"source": "/en/area-circulo/", "destination": "/en/circle-area/", "type": 301},
      {"source": "/fr/area-circulo/", "destination": "/fr/aire-cercle/", "type": 301},
      {"source": "/de/area-circulo/", "destination": "/de/kreisflaeche/", "type": 301},
      {"source": "/it/area-circulo/", "destination": "/it/area-cerchio/", "type": 301},
      {"source": "/en/area-triangulo/", "destination": "/en/triangle-area/", "type": 301},
      {"source": "/fr/area-triangulo/", "destination": "/fr/aire-triangle/", "type": 301},
      {"source": "/de/area-triangulo/", "destination": "/de/dreiecksflaeche/", "type": 301},
      {"source": "/it/area-triangulo/", "destination": "/it/area-triangolo/", "type": 301},
      {"source": "/en/volumen-esfera/", "destination": "/en/sphere-volume/", "type": 301},
      {"source": "/fr/volumen-esfera/", "destination": "/fr/volume-sphere/", "type": 301},
      {"source": "/de/volumen-esfera/", "destination": "/de/kugelvolumen/", "type": 301},
      {"source": "/it/volumen-esfera/", "destination": "/it/volume-sfera/", "type": 301},
      {"source": "/pt/volumen-esfera/", "destination": "/pt/volume-da-esfera/", "type": 301},
      {"source": "/en/volumen-cilindro/", "destination": "/en/cylinder-volume/", "type": 301},
      {"source": "/fr/volumen-cilindro/", "destination": "/fr/volume-cylindre/", "type": 301},
      {"source": "/de/volumen-cilindro/", "destination": "/de/zylindervolumen/", "type": 301},
      {"source": "/it/volumen-cilindro/", "destination": "/it/volume-cilindro/", "type": 301},
      {"source": "/pt/volumen-cilindro/", "destination": "/pt/volume-do-cilindro/", "type": 301},
      {"source": "/en/cono-volumen/", "destination": "/en/cone-volume/", "type": 301},
      {"source": "/fr/cono-volumen/", "destination": "/fr/volume-cone/", "type": 301},
      {"source": "/de/cono-volumen/", "destination": "/de/kegelvolumen/", "type": 301},
      {"source": "/it/cono-volumen/", "destination": "/it/volume-cono/", "type": 301},
      {"source": "/pt/cono-volumen/", "destination": "/pt/volume-do-cone/", "type": 301},
      {"source": "/en/impuesto-ganancias-capital/", "destination": "/en/capital-gains-tax/", "type": 301},
      {"source": "/fr/impuesto-ganancias-capital/", "destination": "/fr/impot-plus-values/", "type": 301},
      {"source": "/de/impuesto-ganancias-capital/", "destination": "/de/kapitalertragsteuer/", "type": 301},
      {"source": "/it/impuesto-ganancias-capital/", "destination": "/it/imposta-plusvalenze/", "type": 301},
      {"source": "/pt/impuesto-ganancias-capital/", "destination": "/pt/imposto-ganhos-capital/", "type": 301},
      {"source": "/en/consumo-combustible/", "destination": "/en/fuel-consumption/", "type": 301},
      {"source": "/fr/consumo-combustible/", "destination": "/fr/consommation-carburant/", "type": 301},
      {"source": "/de/consumo-combustible/", "destination": "/de/kraftstoffverbrauch/", "type": 301},
      {"source": "/it/consumo-combustible/", "destination": "/it/consumo-carburante/", "type": 301},
      {"source": "/pt/consumo-combustible/", "destination": "/pt/consumo-combustivel/", "type": 301},
      {"source": "/en/presion-neumaticos/", "destination": "/en/tire-pressure/", "type": 301},
      {"source": "/fr/presion-neumaticos/", "destination": "/fr/pression-pneus/", "type": 301},
      {"source": "/de/presion-neumaticos/", "destination": "/de/reifendruck/", "type": 301},
      {"source": "/it/presion-neumaticos/", "destination": "/it/pressione-pneumatici/", "type": 301},
      {"source": "/pt/presion-neumaticos/", "destination": "/pt/pressao-pneus/", "type": 301}
    ],
    "headers": [
      {
        "source": "**/",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" },
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "ALLOWALL" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.googletagmanager.com https://*.google-analytics.com https://pagead2.googlesyndication.com https://cdn.jsdelivr.net https://www.gstatic.com https://cdnjs.cloudflare.com https://contextual.media.net https://cdn.carbonads.com https://ayyknrom.com https://*.effectivecpmnetwork.com; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data: https:; connect-src 'self' https://*.googleapis.com https://*.google-analytics.com https://*.cloudfunctions.net; frame-src https://googleads.g.doubleclick.net https:; object-src 'none'; base-uri 'self'" }
        ]
      },
      {
        "source": "/css/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=604800, immutable" },
          { "key": "Vary", "value": "Accept-Encoding" }
        ]
      },
      {
        "source": "/js/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=604800, immutable" },
          { "key": "Vary", "value": "Accept-Encoding" }
        ]
      }
    ],
    "cleanUrls": true,
    "trailingSlash": true
  }
}
