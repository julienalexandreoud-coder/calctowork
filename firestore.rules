rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public analytics write (front-end SDK)
    match /analytics_events/{document} {
      allow create: if request.resource.data.keys().hasAll(['event_name','event_time','session_id'])
                     && request.resource.data.size() < 50
                     && request.time < timestamp.date(2099,1,1);
      allow read: if true;
      allow update, delete: if false;
    }

    match /analytics_daily/{document} {
      allow read: if true;
      allow write: if false;
    }

    // Admin dashboard collections — open read/write (protected by admin.html password gate)
    match /calc_cms/{document} {
      allow read, write: if true;
    }
    match /calc_cms/{document}/{sub=**} {
      allow read, write: if true;
    }
    match /admin_prefs/{document} {
      allow read, write: if true;
    }
    match /calc_pipeline/{document} {
      allow read, write: if true;
    }
    match /seo_suggestions/{document} {
      allow read, write: if true;
    }
    match /growth_reports/{document} {
      allow read, write: if true;
    }
    match /ai_brain/{document} {
      allow read, write: if true;
    }
    match /dashboard_alerts/{document} {
      allow read, write: if true;
    }
    match /rising_page_audits/{document} {
      allow read, write: if true;
    }
    match /gsc_site_stats/{document} {
      allow read: if true;
      allow write: if false;
    }
    match /gsc_page_stats/{document} {
      allow read: if true;
      allow write: if false;
    }
    match /gsc_search_data/{document} {
      allow read: if true;
      allow write: if false;
    }
    match /gsc_index_coverage/{document} {
      allow read: if true;
      allow write: if false;
    }
    match /gsc_coverage/{document} {
      allow read: if true;
      allow write: if false;
    }
  }
}
