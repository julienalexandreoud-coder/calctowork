rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anyone to read/write analytics events
    match /analytics_events/{document} {
      allow create: if true;
      allow read: if true;
    }
    
    // Allow anyone to read daily aggregates
    match /analytics_daily/{document} {
      allow read: if true;
      allow write: if true;
    }
  }
}
